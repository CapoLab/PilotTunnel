#!/usr/bin/env bash
set -euo pipefail

DEFAULT_BASE_DIR="/opt/pilottunnel"
BASE_DIR="$DEFAULT_BASE_DIR"
LINK_LABEL=""
ADAPTER_NAME=""
ATTEMPTS="3"
TIMEOUT_SECONDS="5"
JSON_OUTPUT=0
START_ONLY=0
SMOKE_ONLY=0
RESTORE_PENDING=0
RESTORE_AFTER_SECONDS="${PILOTTUNNEL_TEST_RESTORE_SECONDS:-120}"
PYTHON_BIN=""

REPO_DIR="/opt/pilottunnel/repo"
CONFIG_FILE="/opt/pilottunnel/state/config.json"
STATE_FILE="/opt/pilottunnel/state/state.json"
REGISTRY_FILE="/opt/pilottunnel/state/registry.json"
AUDIT_LOG="/opt/pilottunnel/state/audit.log"
LOCK_DIR="/opt/pilottunnel/state/locks"
WORK_DIR="/opt/pilottunnel/work"
STAGING_ROOT="/opt/pilottunnel/staging"
RESTORE_TRANSACTION_FILE="/opt/pilottunnel/state/benchmark-restore.json"
BIN_DIR="/opt/pilottunnel/bin"
SYSTEMD_UNIT_DIR="${PILOTTUNNEL_TEST_SYSTEMD_DIR:-/etc/systemd/system}"
RESTORE_SERVICE_NAME=""
RESTORE_TIMER_NAME=""

LAST_STDOUT=""
LAST_STDERR=""
LAST_STATUS=0
PREVIOUS_ADAPTER=""
TARGET_STARTED=0

cleanup_capture() {
  [ -n "${LAST_STDOUT:-}" ] && [ -f "$LAST_STDOUT" ] && rm -f "$LAST_STDOUT"
  [ -n "${LAST_STDERR:-}" ] && [ -f "$LAST_STDERR" ] && rm -f "$LAST_STDERR"
  LAST_STDOUT=""
  LAST_STDERR=""
  LAST_STATUS=0
}

trap cleanup_capture EXIT

fail() {
  printf '%s\n' "Error: $*" >&2
  exit 1
}

usage() {
  cat <<EOF
PilotTunnel two-server candidate test runner

Usage:
  pilottunnel-test --link <LINK> --adapter <ADAPTER> [--attempts <N>] [--timeout <SECONDS>]

Options:
  --base-dir <DIR>   PilotTunnel installation root. Defaults to ${DEFAULT_BASE_DIR}.
  --link <LINK>      Candidate link label, for example link-001.
  --adapter <NAME>   Candidate adapter name, for example rathole.
  --attempts <N>     Smoke-test attempt count. Defaults to 3.
  --timeout <SEC>    Per-attempt timeout in seconds. Defaults to 5.
  --json             Print the final summary as JSON.
  --start-only       Prepare and start only. Skip smoke tests.
  --smoke-only       Skip prepare/start and run smoke tests only.
  --restore-pending  Restore an expired local benchmark transaction and exit.
  --restore-after <SEC>
                     Worker start-only restore deadline. Defaults to ${RESTORE_AFTER_SECONDS}.
  --help             Show this help text.
EOF
}

find_python() {
  if command -v python3 >/dev/null 2>&1; then
    printf '%s\n' "python3"
  elif command -v python >/dev/null 2>&1; then
    printf '%s\n' "python"
  else
    printf '%s\n' ""
  fi
}

parse_args() {
  while [ $# -gt 0 ]; do
    case "$1" in
      --base-dir) [ $# -ge 2 ] || fail "--base-dir requires a value"; BASE_DIR="$2"; shift 2 ;;
      --link) [ $# -ge 2 ] || fail "--link requires a value"; LINK_LABEL="$2"; shift 2 ;;
      --adapter) [ $# -ge 2 ] || fail "--adapter requires a value"; ADAPTER_NAME="$2"; shift 2 ;;
      --attempts) [ $# -ge 2 ] || fail "--attempts requires a value"; ATTEMPTS="$2"; shift 2 ;;
      --timeout) [ $# -ge 2 ] || fail "--timeout requires a value"; TIMEOUT_SECONDS="$2"; shift 2 ;;
      --json) JSON_OUTPUT=1; shift ;;
      --start-only) START_ONLY=1; shift ;;
      --smoke-only) SMOKE_ONLY=1; shift ;;
      --restore-pending) RESTORE_PENDING=1; shift ;;
      --restore-after) [ $# -ge 2 ] || fail "--restore-after requires a value"; RESTORE_AFTER_SECONDS="$2"; shift 2 ;;
      --help|-h) usage; exit 0 ;;
      *) fail "Unknown argument: $1" ;;
    esac
  done
}

prepare_paths() {
  case "$BASE_DIR" in
    /*) ;;
    *) BASE_DIR="$(cd "$BASE_DIR" 2>/dev/null && pwd -P)" || fail "Base directory does not exist: $BASE_DIR" ;;
  esac
  REPO_DIR="${BASE_DIR}/repo"
  CONFIG_FILE="${BASE_DIR}/state/config.json"
  STATE_FILE="${BASE_DIR}/state/state.json"
  REGISTRY_FILE="${BASE_DIR}/state/registry.json"
  AUDIT_LOG="${BASE_DIR}/state/audit.log"
  LOCK_DIR="${BASE_DIR}/state/locks"
  WORK_DIR="${BASE_DIR}/work"
  STAGING_ROOT="${BASE_DIR}/staging"
  RESTORE_TRANSACTION_FILE="${BASE_DIR}/state/benchmark-restore.json"
  BIN_DIR="${BASE_DIR}/bin"
  [ -d "$REPO_DIR/pilottunnel" ] || fail "PilotTunnel repository is not installed under $REPO_DIR"
}

validate_args() {
  case "$RESTORE_AFTER_SECONDS" in
    ''|*[!0-9]*) fail "--restore-after must be a non-negative integer" ;;
  esac
  if [ "$RESTORE_PENDING" -eq 1 ]; then
    return 0
  fi
  [ -n "$LINK_LABEL" ] || fail "--link is required"
  [ -n "$ADAPTER_NAME" ] || fail "--adapter is required"
  case "$ATTEMPTS" in
    ''|*[!0-9]*) fail "--attempts must be a positive integer" ;;
  esac
  [ "$ATTEMPTS" -ge 1 ] || fail "--attempts must be at least 1"
  case "$TIMEOUT_SECONDS" in
    ''|*[!0-9.]* ) fail "--timeout must be numeric" ;;
  esac
  if [ "$START_ONLY" -eq 1 ] && [ "$SMOKE_ONLY" -eq 1 ]; then
    fail "--start-only and --smoke-only cannot be used together"
  fi
}

pt() {
  (
    cd "$REPO_DIR" || exit 1
    "$PYTHON_BIN" -m pilottunnel.cli \
      --config "$CONFIG_FILE" \
      --state "$STATE_FILE" \
      --registry "$REGISTRY_FILE" \
      --audit-log "$AUDIT_LOG" \
      --lock-dir "$LOCK_DIR" \
      --work-dir "$WORK_DIR" \
      --staging-root "$STAGING_ROOT" \
      "$@"
  )
}

run_pt_capture() {
  cleanup_capture
  LAST_STDOUT="$(mktemp)"
  LAST_STDERR="$(mktemp)"
  if pt "$@" >"$LAST_STDOUT" 2>"$LAST_STDERR"; then
    LAST_STATUS=0
    return 0
  fi
  LAST_STATUS=$?
  return "$LAST_STATUS"
}

last_payload_ok() {
  "$PYTHON_BIN" - "$LAST_STDOUT" <<'PY'
from pathlib import Path
import json
import sys

text = Path(sys.argv[1]).read_text(encoding="utf-8", errors="replace").strip()
if not text:
    raise SystemExit(0)
try:
    payload = json.loads(text)
except Exception:
    raise SystemExit(0)
if isinstance(payload, dict) and payload.get("ok") is False:
    raise SystemExit(1)
raise SystemExit(0)
PY
}

selected_candidate_prepare_status() {
  "$PYTHON_BIN" - "$LAST_STDOUT" "$ADAPTER_NAME" <<'PY'
from pathlib import Path
import json
import sys

text = Path(sys.argv[1]).read_text(encoding="utf-8", errors="replace").strip()
adapter = sys.argv[2]
try:
    payload = json.loads(text)
except Exception:
    raise SystemExit(1)

if not isinstance(payload, dict):
    raise SystemExit(1)

for candidate in payload.get("candidates") or []:
    if not isinstance(candidate, dict) or candidate.get("adapter") != adapter:
        continue
    if candidate.get("runnable") is True:
        raise SystemExit(0)
    details = [*list(candidate.get("blockers") or []), *list(candidate.get("warnings") or [])]
    if any("Probe/test port" in str(detail) for detail in details):
        raise SystemExit(2)
    raise SystemExit(1)

raise SystemExit(1)
PY
}

json_query() {
  "$PYTHON_BIN" - "$LAST_STDOUT" "$1" <<'PY'
from pathlib import Path
import json
import sys

payload = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8", errors="replace") or "{}")
expr = sys.argv[2]
value = payload
for part in expr.split("."):
    if part == "":
        continue
    if isinstance(value, dict):
        value = value.get(part)
    else:
        value = None
        break
if isinstance(value, (dict, list)):
    print(json.dumps(value))
elif value is None:
    print("")
else:
    print(str(value))
PY
}

json_array_contains_substring() {
  "$PYTHON_BIN" - "$LAST_STDOUT" "$1" "$2" <<'PY'
from pathlib import Path
import json
import sys

payload = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8", errors="replace") or "{}")
field = sys.argv[2]
needle = sys.argv[3]
values = payload.get(field) or []
if not isinstance(values, list):
    raise SystemExit(1)
raise SystemExit(0 if any(needle in str(item) for item in values) else 1)
PY
}

capture_message() {
  "$PYTHON_BIN" - "$LAST_STDOUT" "$LAST_STDERR" <<'PY'
from pathlib import Path
import json
import sys

stdout_text = Path(sys.argv[1]).read_text(encoding="utf-8", errors="replace").strip()
stderr_text = Path(sys.argv[2]).read_text(encoding="utf-8", errors="replace").strip()
if stdout_text:
    try:
        payload = json.loads(stdout_text)
    except Exception:
        print(" ".join(stdout_text.split()))
        raise SystemExit(0)
    if isinstance(payload, dict):
        message = payload.get("message") or payload.get("error") or ""
        print(" ".join(str(message).split()))
        raise SystemExit(0)
if stderr_text:
    print(" ".join(stderr_text.split()))
PY
}

capture_combined_text() {
  "$PYTHON_BIN" - "$LAST_STDOUT" "$LAST_STDERR" <<'PY'
from pathlib import Path
import sys

stdout_text = Path(sys.argv[1]).read_text(encoding="utf-8", errors="replace").strip()
stderr_text = Path(sys.argv[2]).read_text(encoding="utf-8", errors="replace").strip()
combined = " ".join(part for part in (" ".join(stdout_text.split()), " ".join(stderr_text.split())) if part)
print(combined)
PY
}

load_role() {
  run_pt_capture node status || fail "Unable to read node status"
  role="$(json_query normalized_role)"
  cleanup_capture
  [ -n "$role" ] || fail "Node role is not initialized"
  printf '%s\n' "$role"
}

candidate_runtime_active() {
  if ! run_pt_capture candidate result --link "$LINK_LABEL" --json; then
    cleanup_capture
    return 1
  fi
  "$PYTHON_BIN" - "$LAST_STDOUT" "$ADAPTER_NAME" <<'PY'
from pathlib import Path
import json
import sys

payload = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8", errors="replace") or "{}")
adapter = sys.argv[2]
for item in payload.get("candidates") or []:
    if item.get("adapter") != adapter:
        continue
    if item.get("runtime_systemd_state") == "active":
        raise SystemExit(0)
raise SystemExit(1)
PY
  rc=$?
  cleanup_capture
  return $rc
}

candidate_local_services_active() {
  run_pt_capture candidate result --link "$LINK_LABEL" --json || true
  if [ "$LAST_STATUS" -ne 0 ] || ! last_payload_ok; then
    return 1
  fi
  "$PYTHON_BIN" - "$LAST_STDOUT" "$ADAPTER_NAME" <<'PY'
from pathlib import Path
import json
import sys

payload = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8", errors="replace") or "{}")
adapter = sys.argv[2]
for item in payload.get("candidates") or []:
    if item.get("adapter") != adapter:
        continue
    services = item.get("runtime_services") or []
    if item.get("runtime_systemd_ok") is not True or not services:
        raise SystemExit(1)
    for service in services:
        if service.get("active_state") != "active" or service.get("sub_state") not in {"running", "exited", "listening"}:
            raise SystemExit(1)
    raise SystemExit(0)
raise SystemExit(1)
PY
}

active_candidate_adapter() {
  active_candidate_adapter_for_link "$LINK_LABEL"
}

active_candidate_adapter_for_link() {
  run_pt_capture candidate result --link "$1" --json || true
  if [ "$LAST_STATUS" -ne 0 ] || ! last_payload_ok; then
    printf '%s\n' ""
    return 1
  fi
  json_query active_adapter
}

begin_benchmark_transaction() {
  PREVIOUS_ADAPTER="$(active_candidate_adapter || true)"
  cleanup_capture
  if [ -n "$PREVIOUS_ADAPTER" ] && [ "$PREVIOUS_ADAPTER" != "$ADAPTER_NAME" ]; then
    run_pt_capture candidate stop --link "$LINK_LABEL" --json || true
    if ! { [ "$LAST_STATUS" -eq 0 ] && last_payload_ok; }; then
      return 1
    fi
    cleanup_capture
  fi
  return 0
}

restore_previous_candidate() {
  if [ -z "$PREVIOUS_ADAPTER" ] || [ "$PREVIOUS_ADAPTER" = "$ADAPTER_NAME" ]; then
    return 0
  fi
  run_pt_capture candidate stop --link "$LINK_LABEL" --json || true
  if ! { [ "$LAST_STATUS" -eq 0 ] && last_payload_ok; }; then
    return 1
  fi
  cleanup_capture
  run_pt_capture candidate prepare-all --link "$LINK_LABEL" --json || true
  if ! { [ "$LAST_STATUS" -eq 0 ] && last_payload_ok; }; then
    return 1
  fi
  cleanup_capture
  run_pt_capture candidate start --adapter "$PREVIOUS_ADAPTER" --link "$LINK_LABEL" --json || true
  if ! { [ "$LAST_STATUS" -eq 0 ] && last_payload_ok; }; then
    return 1
  fi
  cleanup_capture
  TARGET_STARTED=0
  return 0
}

restore_unit_scope() {
  "$PYTHON_BIN" - "$BASE_DIR" "$1" <<'PY'
import hashlib
import re
import sys
base_dir = sys.argv[1]
link = sys.argv[2]
safe_link = re.sub(r"[^A-Za-z0-9_-]+", "-", link).strip("-").lower() or "link"
safe_link = safe_link[:32]
digest = hashlib.sha256(f"{base_dir}\0{link}".encode("utf-8")).hexdigest()[:12]
print(f"{safe_link}-{digest}")
PY
}

set_restore_unit_names() {
  scope="$(restore_unit_scope "$1")"
  RESTORE_SERVICE_NAME="pilottunnel-benchmark-restore-${scope}.service"
  RESTORE_TIMER_NAME="pilottunnel-benchmark-restore-${scope}.timer"
}

systemd_quote_arg() {
  "$PYTHON_BIN" - "$1" <<'PY'
import sys
value = sys.argv[1]
escaped = value.replace("\\", "\\\\").replace('"', '\\"')
print(f'"{escaped}"')
PY
}

deadline_calendar_utc() {
  "$PYTHON_BIN" - "$1" <<'PY'
from datetime import datetime, timezone
import sys
epoch = int(sys.argv[1])
print(datetime.fromtimestamp(epoch, tz=timezone.utc).strftime("%Y-%m-%d %H:%M:%S UTC"))
PY
}

write_restore_transaction() {
  if [ -z "$PREVIOUS_ADAPTER" ] || [ "$PREVIOUS_ADAPTER" = "$ADAPTER_NAME" ]; then
    return 0
  fi
  set_restore_unit_names "$LINK_LABEL"
  mkdir -p "$(dirname "$RESTORE_TRANSACTION_FILE")"
  "$PYTHON_BIN" - "$RESTORE_TRANSACTION_FILE" "$LINK_LABEL" "$PREVIOUS_ADAPTER" "$ADAPTER_NAME" "$RESTORE_AFTER_SECONDS" "$RESTORE_SERVICE_NAME" "$RESTORE_TIMER_NAME" "$BASE_DIR" <<'PY'
from pathlib import Path
from datetime import datetime, timezone
import json
import sys
import time

path = Path(sys.argv[1])
deadline_after = int(sys.argv[5])
service_name = sys.argv[6]
timer_name = sys.argv[7]
base_dir = sys.argv[8]
if path.exists():
    try:
        existing = json.loads(path.read_text(encoding="utf-8"))
    except Exception as exc:
        print(f"Existing benchmark restore transaction is malformed: {exc}", file=sys.stderr)
        raise SystemExit(2)
    if existing.get("status") == "pending":
        print("A benchmark restore transaction is already pending", file=sys.stderr)
        raise SystemExit(2)
now = int(time.time())
deadline = now + deadline_after
payload = {
    "status": "pending",
    "link": sys.argv[2],
    "previous_adapter": sys.argv[3],
    "target_adapter": sys.argv[4],
    "base_dir": base_dir,
    "service_name": service_name,
    "timer_name": timer_name,
    "created_at_epoch": now,
    "deadline_epoch": deadline,
    "deadline_utc": datetime.fromtimestamp(deadline, tz=timezone.utc).isoformat(),
}
tmp = path.with_suffix(path.suffix + ".tmp")
tmp.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
tmp.replace(path)
PY
}

mark_restore_transaction_complete() {
  "$PYTHON_BIN" - "$RESTORE_TRANSACTION_FILE" <<'PY'
from pathlib import Path
import json
import sys
import time

path = Path(sys.argv[1])
if not path.exists():
    raise SystemExit(0)
try:
    payload = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    payload = {}
payload["status"] = "complete"
payload["completed_at_epoch"] = int(time.time())
path.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
PY
}

restore_transaction_field() {
  "$PYTHON_BIN" - "$RESTORE_TRANSACTION_FILE" "$1" <<'PY'
from pathlib import Path
import json
import sys

path = Path(sys.argv[1])
field = sys.argv[2]
if not path.exists():
    print("")
    raise SystemExit(0)
try:
    payload = json.loads(path.read_text(encoding="utf-8"))
except Exception as exc:
    print(f"Malformed benchmark restore transaction: {exc}", file=sys.stderr)
    raise SystemExit(2)
print(payload.get(field, ""))
PY
}

restore_transaction_expired() {
  "$PYTHON_BIN" - "$RESTORE_TRANSACTION_FILE" <<'PY'
from pathlib import Path
import json
import sys
import time

path = Path(sys.argv[1])
if not path.exists():
    raise SystemExit(1)
try:
    payload = json.loads(path.read_text(encoding="utf-8"))
except Exception as exc:
    print(f"Malformed benchmark restore transaction: {exc}", file=sys.stderr)
    raise SystemExit(2)
if payload.get("status") != "pending":
    raise SystemExit(1)
try:
    deadline = int(payload.get("deadline_epoch"))
except Exception:
    print("Pending restore transaction has an invalid deadline", file=sys.stderr)
    raise SystemExit(2)
raise SystemExit(0 if deadline <= int(time.time()) else 1)
PY
}

schedule_restore_deadline() {
  if [ -z "$PREVIOUS_ADAPTER" ] || [ "$PREVIOUS_ADAPTER" = "$ADAPTER_NAME" ]; then
    return 0
  fi
  set_restore_unit_names "$LINK_LABEL"
  deadline_epoch="$(restore_transaction_field deadline_epoch)" || return 1
  deadline_calendar="$(deadline_calendar_utc "$deadline_epoch")" || return 1
  mkdir -p "$SYSTEMD_UNIT_DIR" || return 1
  runner_path="${BIN_DIR}/pilottunnel-test"
  quoted_runner="$(systemd_quote_arg "$runner_path")" || return 1
  quoted_base="$(systemd_quote_arg "$BASE_DIR")" || return 1
  quoted_transaction="$(systemd_quote_arg "$RESTORE_TRANSACTION_FILE")" || return 1
  service_path="${SYSTEMD_UNIT_DIR}/${RESTORE_SERVICE_NAME}"
  timer_path="${SYSTEMD_UNIT_DIR}/${RESTORE_TIMER_NAME}"
  service_tmp="${service_path}.tmp"
  timer_tmp="${timer_path}.tmp"
  cat >"$service_tmp" <<EOF
[Unit]
Description=PilotTunnel benchmark restore guard
Documentation=https://github.com/CapoLab/PilotTunnel
ConditionPathExists=${quoted_transaction}

[Service]
Type=oneshot
ExecStart=${quoted_runner} --base-dir ${quoted_base} --restore-pending
EOF
  mv "$service_tmp" "$service_path" || return 1
  cat >"$timer_tmp" <<EOF
[Unit]
Description=PilotTunnel benchmark restore deadline timer
Documentation=https://github.com/CapoLab/PilotTunnel

[Timer]
OnCalendar=${deadline_calendar}
AccuracySec=1s
Persistent=true
Unit=${RESTORE_SERVICE_NAME}

[Install]
WantedBy=timers.target
EOF
  mv "$timer_tmp" "$timer_path" || return 1
  systemctl daemon-reload || return 1
  systemctl enable --now "$RESTORE_TIMER_NAME" || return 1
}

disable_restore_deadline() {
  service_name="$1"
  timer_name="$2"
  [ -n "$service_name" ] || return 0
  [ -n "$timer_name" ] || return 0
  systemctl disable --now "$timer_name" || return 1
  rm -f "${SYSTEMD_UNIT_DIR}/${timer_name}" "${SYSTEMD_UNIT_DIR}/${service_name}" || return 1
  systemctl daemon-reload || return 1
}

complete_restore_transaction() {
  service_name="$(restore_transaction_field service_name)" || return 1
  timer_name="$(restore_transaction_field timer_name)" || return 1
  disable_restore_deadline "$service_name" "$timer_name" || return 1
  mark_restore_transaction_complete || return 1
}

restore_pending_transaction() {
  if [ ! -f "$RESTORE_TRANSACTION_FILE" ]; then
    printf '%s\n' "No pending PilotTunnel benchmark restore transaction."
    return 0
  fi
  if ! status="$(restore_transaction_field status)"; then
    fail "Pending benchmark restore transaction is malformed or unreadable"
  fi
  if [ "$status" != "pending" ]; then
    printf '%s\n' "No pending PilotTunnel benchmark restore transaction."
    return 0
  fi
  if restore_transaction_expired; then
    :
  else
    rc=$?
    if [ "$rc" -eq 2 ]; then
      fail "Pending benchmark restore transaction is malformed or unreadable"
    fi
    printf '%s\n' "PilotTunnel benchmark restore transaction is not expired yet."
    return 0
  fi
  tx_link="$(restore_transaction_field link)" || fail "Pending benchmark restore transaction is malformed or unreadable"
  tx_previous="$(restore_transaction_field previous_adapter)" || fail "Pending benchmark restore transaction is malformed or unreadable"
  tx_target="$(restore_transaction_field target_adapter)" || fail "Pending benchmark restore transaction is malformed or unreadable"
  [ -n "$tx_link" ] || fail "Pending restore transaction is missing link"
  [ -n "$tx_target" ] || fail "Pending restore transaction is missing temporary candidate"
  [ -n "$tx_previous" ] || fail "Pending restore transaction is missing previous candidate"
  current_adapter="$(active_candidate_adapter_for_link "$tx_link" || true)"
  cleanup_capture
  if [ "$current_adapter" = "$tx_previous" ]; then
    complete_restore_transaction || fail "Previous candidate is active, but restore timer cleanup failed"
    printf '%s\n' "PilotTunnel benchmark restore transaction was already restored locally for link ${tx_link}."
    return 0
  fi
  if [ "$current_adapter" = "$tx_target" ]; then
    run_pt_capture candidate stop --link "$tx_link" --json || true
    if ! { [ "$LAST_STATUS" -eq 0 ] && last_payload_ok; }; then
      message="$(capture_message)"
      cleanup_capture
      fail "${message:-failed to stop temporary candidate during pending restore}"
    fi
    cleanup_capture
  fi
  run_pt_capture candidate prepare-all --link "$tx_link" --json || true
  if ! { [ "$LAST_STATUS" -eq 0 ] && last_payload_ok; }; then
    message="$(capture_message)"
    cleanup_capture
    fail "${message:-failed to prepare previous candidate during pending restore}"
  fi
  cleanup_capture
  run_pt_capture candidate start --adapter "$tx_previous" --link "$tx_link" --json || true
  if ! { [ "$LAST_STATUS" -eq 0 ] && last_payload_ok; }; then
    message="$(capture_message)"
    cleanup_capture
    fail "${message:-failed to restore previous candidate during pending restore}"
  fi
  cleanup_capture
  complete_restore_transaction || fail "Previous candidate was restored, but restore timer cleanup failed"
  printf '%s\n' "PilotTunnel benchmark restore completed locally for link ${tx_link}: stopped ${tx_target}, restored ${tx_previous}."
}

manual_daemon_reload() {
  systemctl daemon-reload
}

prepare_all_with_worker_retry() {
  run_pt_capture candidate prepare-all --link "$LINK_LABEL" --json || true
  selected_status=1
  if selected_candidate_prepare_status; then
    selected_status=0
  else
    selected_status=$?
  fi
  if [ "$LAST_STATUS" -eq 0 ] && last_payload_ok && [ "$selected_status" -eq 0 ]; then
    return 0
  fi
  if [ "$selected_status" -eq 2 ]; then
    run_pt_capture candidate stop --adapter "$ADAPTER_NAME" --link "$LINK_LABEL" --json || true
    if [ "$LAST_STATUS" -eq 0 ] && last_payload_ok; then
      cleanup_capture
      run_pt_capture candidate prepare-all --link "$LINK_LABEL" --json || true
      if [ "$LAST_STATUS" -eq 0 ] && last_payload_ok && selected_candidate_prepare_status; then
        return 0
      fi
    fi
  fi
  return 1
}

start_candidate_with_controller_retry() {
  run_pt_capture candidate start --adapter "$ADAPTER_NAME" --link "$LINK_LABEL" --json || true
  if [ "$LAST_STATUS" -eq 0 ] && last_payload_ok; then
    return 0
  fi
  message="$(capture_combined_text)"
  if printf '%s' "$message" | grep -Fq "Command timed out: systemctl daemon-reload"; then
    if manual_daemon_reload; then
      cleanup_capture
      run_pt_capture candidate start --adapter "$ADAPTER_NAME" --link "$LINK_LABEL" --json || true
      if [ "$LAST_STATUS" -eq 0 ] && last_payload_ok; then
        return 0
      fi
    fi
  fi
  return 1
}

emit_summary() {
  summary_json="$1"
  if [ "$JSON_OUTPUT" -eq 1 ]; then
    printf '%s\n' "$summary_json"
    return
  fi
  "$PYTHON_BIN" - "$summary_json" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1])
print(f"ok: {str(payload.get('ok', False)).lower()}")
print(f"role: {payload.get('role', '')}")
print(f"link: {payload.get('link', '')}")
print(f"adapter: {payload.get('adapter', '')}")
print(f"runtime_config: {payload.get('runtime_config', '') or 'unknown'}")
print(f"probe result: {payload.get('probe_result', '') or 'skipped'}")
print(f"real result: {payload.get('real_result', '') or 'skipped'}")
status = payload.get("status")
if status:
    print(f"status: {status}")
message = payload.get("message")
if message:
    print(f"message: {message}")
PY
}

worker_summary() {
  runtime_config="$1"
  message="$2"
  "$PYTHON_BIN" - "$LINK_LABEL" "$ADAPTER_NAME" "$runtime_config" "$message" <<'PY'
import json
import sys
print(json.dumps({
    "ok": True,
    "role": "worker",
    "link": sys.argv[1],
    "adapter": sys.argv[2],
    "status": "worker_ready",
    "runtime_config": sys.argv[3] or "unknown",
    "probe_result": "skipped",
    "real_result": "skipped",
    "message": sys.argv[4] or "worker ready"
}, indent=2))
PY
}

controller_summary() {
  runtime_config="$1"
  probe_result="$2"
  real_result="$3"
  message="$4"
  "$PYTHON_BIN" - "$LINK_LABEL" "$ADAPTER_NAME" "$runtime_config" "$probe_result" "$real_result" "$message" <<'PY'
import json
import sys
probe_result = sys.argv[4] or "skipped"
real_result = sys.argv[5] or "skipped"
ok = (probe_result == "passed" and real_result == "passed") or (probe_result == "skipped" and real_result == "skipped")
print(json.dumps({
    "ok": ok,
    "role": "controller",
    "link": sys.argv[1],
    "adapter": sys.argv[2],
    "status": "controller_test_complete" if ok else "controller_test_failed",
    "runtime_config": sys.argv[3] or "unknown",
    "probe_result": probe_result,
    "real_result": real_result,
    "message": sys.argv[6],
}, indent=2))
PY
}

run_worker_flow() {
  if [ "$SMOKE_ONLY" -eq 1 ]; then
    fail "Worker role does not support --smoke-only. Use the controller side for smoke tests."
  fi
  if ! begin_benchmark_transaction; then
    message="$(capture_message)"
    cleanup_capture
    fail "${message:-failed to stop the currently active local candidate before worker benchmark start}"
  fi
  if ! prepare_all_with_worker_retry; then
    message="$(capture_message)"
    cleanup_capture
    restore_previous_candidate || true
    fail "${message:-candidate prepare-all failed on worker}"
  fi
  cleanup_capture
  run_pt_capture candidate start --adapter "$ADAPTER_NAME" --link "$LINK_LABEL" --json || true
  if ! { [ "$LAST_STATUS" -eq 0 ] && last_payload_ok; }; then
    message="$(capture_message)"
    cleanup_capture
    restore_previous_candidate || true
    fail "${message:-candidate start failed on worker}"
  fi
  TARGET_STARTED=1
  if [ "$START_ONLY" -eq 1 ]; then
    if ! write_restore_transaction; then
      cleanup_capture
      if restore_previous_candidate; then
        fail "Failed to persist durable local restore transaction; restored the previous local candidate"
      fi
      fail "Failed to persist durable local restore transaction, and restoring the previous local candidate also failed"
    fi
    if ! schedule_restore_deadline; then
      cleanup_capture
      if restore_previous_candidate; then
        mark_restore_transaction_complete || fail "Failed to schedule durable local restore deadline; previous candidate was restored but transaction completion failed"
        fail "Failed to schedule durable local restore deadline; restored the previous local candidate"
      fi
      fail "Failed to schedule durable local restore deadline, and restoring the previous local candidate also failed"
    fi
  fi
  runtime_config="$(json_query runtime_config_status)"
  message="$(capture_message)"
  cleanup_capture
  emit_summary "$(worker_summary "$runtime_config" "${message:-worker ready}")"
}

run_controller_flow() {
  probe_result="skipped"
  real_result="skipped"
  runtime_config="unknown"
  if [ "$SMOKE_ONLY" -eq 0 ]; then
    if ! begin_benchmark_transaction; then
      message="$(capture_message)"
      cleanup_capture
      fail "${message:-failed to stop the currently active local candidate before controller benchmark start}"
    fi
    run_pt_capture candidate prepare-all --link "$LINK_LABEL" --json || true
    if ! { [ "$LAST_STATUS" -eq 0 ] && last_payload_ok; }; then
      message="$(capture_message)"
      cleanup_capture
      restore_previous_candidate || true
      fail "${message:-candidate prepare-all failed on controller}"
    fi
    cleanup_capture
    if ! start_candidate_with_controller_retry; then
      message="$(capture_message)"
      cleanup_capture
      restore_previous_candidate || true
      fail "${message:-candidate start failed on controller}"
    fi
    TARGET_STARTED=1
    runtime_config="$(json_query runtime_config_status)"
    cleanup_capture
  fi
  if [ "$START_ONLY" -eq 0 ]; then
    if ! candidate_local_services_active; then
      cleanup_capture
      restore_previous_candidate || true
      fail "Candidate local services are not active; refusing to run smoke tests"
    fi
    cleanup_capture
    run_pt_capture candidate smoke-test --adapter "$ADAPTER_NAME" --link "$LINK_LABEL" --mode probe --attempts "$ATTEMPTS" --timeout "$TIMEOUT_SECONDS" --json || true
    if ! { [ "$LAST_STATUS" -eq 0 ] && last_payload_ok; }; then
      message="$(capture_message)"
      probe_result="failed"
      cleanup_capture
      restore_previous_candidate || true
      fail "${message:-probe smoke test failed}"
    fi
    probe_result="$(json_query result.probe_status)"
    runtime_config="${runtime_config:-$(json_query runtime_config_status)}"
    cleanup_capture
    run_pt_capture candidate smoke-test --adapter "$ADAPTER_NAME" --link "$LINK_LABEL" --mode real_service --attempts "$ATTEMPTS" --timeout "$TIMEOUT_SECONDS" --json || true
    if ! { [ "$LAST_STATUS" -eq 0 ] && last_payload_ok; }; then
      message="$(capture_message)"
      real_result="failed"
      cleanup_capture
      restore_previous_candidate || true
      fail "${message:-real service smoke test failed}"
    fi
    real_result="$(json_query result.real_service_status)"
    runtime_config="${runtime_config:-$(json_query runtime_config_status)}"
    cleanup_capture
  fi
  restore_previous_candidate || true
  emit_summary "$(controller_summary "$runtime_config" "$probe_result" "$real_result" "controller flow complete")"
}

main() {
  parse_args "$@"
  PYTHON_BIN="$(find_python)"
  [ -n "$PYTHON_BIN" ] || fail "Python is required but was not found."
  prepare_paths
  validate_args
  if [ "$RESTORE_PENDING" -eq 1 ]; then
    restore_pending_transaction
    exit 0
  fi
  role="$(load_role)"
  case "$role" in
    worker) run_worker_flow ;;
    controller) run_controller_flow ;;
    *) fail "Unsupported node role: $role" ;;
  esac
}

if [ "${BASH_SOURCE[0]}" = "$0" ]; then
  main "$@"
fi
