#!/usr/bin/env bash
set -uo pipefail

DEFAULT_BASE_DIR="/opt/pilottunnel"
BASE_DIR="$DEFAULT_BASE_DIR"
PYTHON_BIN=""
TERM_WIDTH=88
PANEL_WIDTH=80
MENU_DEBUG="${PILOTTUNNEL_MENU_DEBUG:-0}"

RESET=""
BOLD=""
DIM=""
FRAME=""
TITLE=""
ACCENT=""
INFO_COLOR=""
SUCCESS_COLOR=""
WARN_COLOR=""
ERROR_COLOR=""
VALUE_COLOR=""
PROMPT_COLOR=""

NODE_INITIALIZED="false"
NODE_ROLE=""
NODE_ROLE_LABEL="not configured"
NODE_DISPLAY_NAME=""
NODE_INSTALL_ROOT=""
NODE_STATE_DIRECTORY=""
NODE_WORK_DIRECTORY=""
NODE_ENDPOINT_ADDRESS=""
NODE_NOTES=""
NODE_ID=""
NODE_CONFIG_PATH=""
NODE_PREFERRED_LAYER=""
NODE_MANAGED_ENDPOINT_COUNT="0"
CURRENT_LINK_COUNT="0"
CURRENT_LINK_ID=""
CURRENT_LINK_LABEL=""
CURRENT_LOCAL_SIDE=""
CURRENT_LOCAL_ADDRESS=""
CURRENT_REMOTE_ADDRESS=""
CURRENT_IRAN_MAIN_PORT=""
CURRENT_TUNNEL_PORT=""
CURRENT_CONFIG_PORT=""
CURRENT_PAIRING_STATE=""
CURRENT_NEXT_ACTION=""
CURRENT_LINK_STATUS=""

fail() {
  printf '%s\n' "Error: $*" >&2
  exit 1
}

usage() {
  cat <<EOF
PilotTunnel terminal menu

Usage:
  pilottunnel-menu [--base-dir <DIR>]

Options:
  --base-dir <DIR>  PilotTunnel installation root. Defaults to ${DEFAULT_BASE_DIR}.
  --help            Show this help text.
EOF
}

parse_args() {
  while [ $# -gt 0 ]; do
    case "$1" in
      --base-dir) [ $# -ge 2 ] || fail "--base-dir requires a value"; BASE_DIR="$2"; shift 2 ;;
      --help|-h) usage; exit 0 ;;
      *) fail "Unknown argument: $1" ;;
    esac
  done
}

find_python() {
  if command -v python3 >/dev/null 2>&1; then
    printf '%s\n' "python3"
  elif command -v python >/dev/null 2>&1; then
    printf '%s\n' "python"
  else
    printf '%s\n' ""
  fi
}

prepare_paths() {
  case "$BASE_DIR" in
    /*) ;;
    *) BASE_DIR="$(cd "$BASE_DIR" 2>/dev/null && pwd -P)" || fail "Base directory does not exist: $BASE_DIR" ;;
  esac
  REPO_DIR="${BASE_DIR}/repo"
  STATE_DIR="${BASE_DIR}/state"
  WORK_DIR="${BASE_DIR}/work"
  STAGING_ROOT="${BASE_DIR}/staging"
  INSTALL_ROOT="${BASE_DIR}/install-root"
  CONFIG_FILE="${STATE_DIR}/config.json"
  STATE_FILE="${STATE_DIR}/state.json"
  REGISTRY_FILE="${STATE_DIR}/registry.json"
  AUDIT_LOG="${STATE_DIR}/audit.log"
  LOCK_DIR="${STATE_DIR}/locks"
  [ -d "$REPO_DIR/pilottunnel" ] || fail "PilotTunnel repository is not installed under $REPO_DIR"
}

pt_cli() {
  (
    cd "$REPO_DIR" || exit 1
    "$PYTHON_BIN" -m pilottunnel.cli \
      --config "$CONFIG_FILE" \
      --state "$STATE_FILE" \
      --registry "$REGISTRY_FILE" \
      --audit-log "$AUDIT_LOG" \
      --lock-dir "$LOCK_DIR" \
      --work-dir "$WORK_DIR" \
      --staging-root "$STAGING_ROOT" \
      "$@"
  )
}

init_theme() {
  if [ "${NO_COLOR:-}" = "" ] && { [ -t 1 ] || [ "${PILOTTUNNEL_MENU_ALLOW_NON_TTY:-0}" = "1" ]; }; then
    ESC="$(printf '\033')"
    RESET="${ESC}[0m"
    BOLD="${ESC}[1m"
    DIM="${ESC}[2m"
    FRAME="${ESC}[38;5;81m"
    TITLE="${ESC}[38;5;51m"
    ACCENT="${ESC}[38;5;226m"
    INFO_COLOR="${ESC}[38;5;117m"
    SUCCESS_COLOR="${ESC}[38;5;84m"
    WARN_COLOR="${ESC}[38;5;214m"
    ERROR_COLOR="${ESC}[38;5;203m"
    VALUE_COLOR="${ESC}[38;5;195m"
    PROMPT_COLOR="${ESC}[38;5;159m"
  fi

  if command -v tput >/dev/null 2>&1; then
    detected_width="$(tput cols 2>/dev/null || printf '%s\n' 88)"
  else
    detected_width=88
  fi
  case "$detected_width" in
    ''|*[!0-9]*) detected_width=88 ;;
  esac
  TERM_WIDTH="$detected_width"
  PANEL_WIDTH=$((TERM_WIDTH - 8))
  if [ "$PANEL_WIDTH" -lt 68 ]; then
    PANEL_WIDTH=68
  fi
  if [ "$PANEL_WIDTH" -gt 104 ]; then
    PANEL_WIDTH=104
  fi
}

repeat_char() {
  char="$1"
  count="$2"
  output=""
  while [ "$count" -gt 0 ]; do
    output="${output}${char}"
    count=$((count - 1))
  done
  printf '%s' "$output"
}

center_text() {
  text="$1"
  width="$2"
  text_length=${#text}
  if [ "$text_length" -ge "$width" ]; then
    printf '%s' "$text"
    return
  fi
  left_padding=$(((width - text_length) / 2))
  right_padding=$((width - text_length - left_padding))
  printf '%*s%s%*s' "$left_padding" "" "$text" "$right_padding" ""
}

box_border() {
  printf '%b+%s+%b\n' "$FRAME" "$(repeat_char "=" "$PANEL_WIDTH")" "$RESET"
}

box_rule() {
  printf '%b|%s|%b\n' "$FRAME" "$(repeat_char "-" "$PANEL_WIDTH")" "$RESET"
}

box_line_center() {
  text="$1"
  color="${2:-$VALUE_COLOR}"
  padded="$(center_text "$text" "$PANEL_WIDTH")"
  printf '%b|%b%s%b|%b\n' "$FRAME" "$color" "$padded" "$RESET" "$RESET"
}

box_line_left() {
  text="$1"
  color="${2:-$VALUE_COLOR}"
  printf '%b|%b %-*s %b|%b\n' "$FRAME" "$color" $((PANEL_WIDTH - 2)) "$text" "$RESET" "$RESET"
}

box_blank() {
  printf '%b|%*s|%b\n' "$FRAME" "$PANEL_WIDTH" "" "$RESET"
}

clear_screen() {
  printf '\033[2J\033[H'
}

info() {
  printf '%b[%s]%b %s\n' "$INFO_COLOR$BOLD" "INFO" "$RESET" "$*"
}

success() {
  printf '%b[%s]%b %s\n' "$SUCCESS_COLOR$BOLD" "OK" "$RESET" "$*"
}

warning() {
  printf '%b[%s]%b %s\n' "$WARN_COLOR$BOLD" "WARN" "$RESET" "$*"
}

error_line() {
  printf '%b[%s]%b %s\n' "$ERROR_COLOR$BOLD" "ERROR" "$RESET" "$*"
}

menu_hint() {
  printf '%b%s%b\n' "$DIM" "$*" "$RESET"
}

prompt_input() {
  printf '%b> %b' "$PROMPT_COLOR$BOLD" "$RESET"
}

normalize_input() {
  printf '%s' "${1%$'\r'}"
}

installed_version() {
  (
    cd "$REPO_DIR" || exit 1
    "$PYTHON_BIN" -c 'from pilottunnel.__version__ import VERSION; print(VERSION)'
  ) 2>/dev/null || printf '%s\n' "unknown"
}

role_label() {
  case "$1" in
    controller) printf '%s\n' "Iran side / controller" ;;
    worker) printf '%s\n' "Kharej side / worker" ;;
    *) printf '%s\n' "not configured" ;;
  esac
}

side_name() {
  case "$1" in
    controller) printf '%s\n' "Iran side" ;;
    worker) printf '%s\n' "Kharej side" ;;
    *) printf '%s\n' "not configured" ;;
  esac
}

current_node_snapshot() {
  (
    cd "$REPO_DIR" || exit 1
    "$PYTHON_BIN" - "$CONFIG_FILE" "$BASE_DIR" "$STATE_DIR" "$WORK_DIR" <<'PY'
from pathlib import Path
import sys

from pilottunnel.config import load_config

config = load_config(Path(sys.argv[1]))
default_install_root = sys.argv[2]
default_state_directory = sys.argv[3]
default_work_directory = sys.argv[4]
role = config.node.normalized_role
role_label = {
    "controller": "Iran side / controller",
    "worker": "Kharej side / worker",
}.get(role, "not configured")
values = [
    "true" if config.node.initialized else "false",
    role,
    role_label,
    config.node.display_name or "",
    config.node.install_root or default_install_root,
    config.node.state_directory or default_state_directory,
    config.node.work_directory or default_work_directory,
    config.node.endpoint_address or "",
    config.node.notes or "",
    config.node.node_id or "",
    str(Path(sys.argv[1])),
    config.node.preferred_layer or "",
    str(len(config.node.managed_remote_endpoints or [])),
]
for value in values:
    print(str(value).replace("\n", " ").strip())
PY
  )
}

load_node_snapshot() {
  mapfile -t snapshot < <(current_node_snapshot)
  NODE_INITIALIZED="$(normalize_input "${snapshot[0]:-false}")"
  NODE_ROLE="$(normalize_input "${snapshot[1]:-}")"
  NODE_ROLE_LABEL="$(normalize_input "${snapshot[2]:-not configured}")"
  NODE_DISPLAY_NAME="$(normalize_input "${snapshot[3]:-}")"
  NODE_INSTALL_ROOT="$(normalize_input "${snapshot[4]:-$BASE_DIR}")"
  NODE_STATE_DIRECTORY="$(normalize_input "${snapshot[5]:-$STATE_DIR}")"
  NODE_WORK_DIRECTORY="$(normalize_input "${snapshot[6]:-$WORK_DIR}")"
  NODE_ENDPOINT_ADDRESS="$(normalize_input "${snapshot[7]:-}")"
  NODE_NOTES="$(normalize_input "${snapshot[8]:-}")"
  NODE_ID="$(normalize_input "${snapshot[9]:-}")"
  NODE_CONFIG_PATH="$(normalize_input "${snapshot[10]:-$CONFIG_FILE}")"
  NODE_PREFERRED_LAYER="$(normalize_input "${snapshot[11]:-}")"
  NODE_MANAGED_ENDPOINT_COUNT="$(normalize_input "${snapshot[12]:-0}")"
}

current_link_snapshot() {
  (
    cd "$REPO_DIR" || exit 1
    "$PYTHON_BIN" - "$CONFIG_FILE" <<'PY'
from pathlib import Path
import sys

from pilottunnel.config import load_config
from pilottunnel.links import get_active_link, link_payload

config = load_config(Path(sys.argv[1]))
link = get_active_link(config)
payload = link_payload(link, active_label=config.node.active_link_label, role=config.node.normalized_role) if link else {}
values = [
    str(len(config.links)),
    payload.get("id", "") or "",
    payload.get("label", "") or "",
    payload.get("local_side", "") or "",
    payload.get("detected_local_address", "") or "",
    payload.get("remote_address", "") or "",
    "" if payload.get("controller_user_facing_port") is None else str(payload.get("controller_user_facing_port")),
    "" if payload.get("transport_port") is None else str(payload.get("transport_port")),
    "" if payload.get("worker_service_port") is None else str(payload.get("worker_service_port")),
    payload.get("pairing_state", "") or "",
    payload.get("next_action", "") or "",
    payload.get("status", "") or "",
]
for value in values:
    print(str(value).replace("\n", " ").strip())
PY
  )
}

load_link_snapshot() {
  mapfile -t snapshot < <(current_link_snapshot)
  CURRENT_LINK_COUNT="$(normalize_input "${snapshot[0]:-0}")"
  CURRENT_LINK_ID="$(normalize_input "${snapshot[1]:-}")"
  CURRENT_LINK_LABEL="$(normalize_input "${snapshot[2]:-}")"
  CURRENT_LOCAL_SIDE="$(normalize_input "${snapshot[3]:-}")"
  CURRENT_LOCAL_ADDRESS="$(normalize_input "${snapshot[4]:-}")"
  CURRENT_REMOTE_ADDRESS="$(normalize_input "${snapshot[5]:-}")"
  CURRENT_IRAN_MAIN_PORT="$(normalize_input "${snapshot[6]:-}")"
  CURRENT_TUNNEL_PORT="$(normalize_input "${snapshot[7]:-}")"
  CURRENT_CONFIG_PORT="$(normalize_input "${snapshot[8]:-}")"
  CURRENT_PAIRING_STATE="$(normalize_input "${snapshot[9]:-}")"
  CURRENT_NEXT_ACTION="$(normalize_input "${snapshot[10]:-}")"
  CURRENT_LINK_STATUS="$(normalize_input "${snapshot[11]:-}")"
}

run_cli_capture() {
  LAST_CAPTURE_STDOUT="$(mktemp)"
  LAST_CAPTURE_STDERR="$(mktemp)"
  if ! pt_cli "$@" >"$LAST_CAPTURE_STDOUT" 2>"$LAST_CAPTURE_STDERR"; then
    return 1
  fi
  return 0
}

run_cli_capture_allow_failure() {
  LAST_CAPTURE_STDOUT="$(mktemp)"
  LAST_CAPTURE_STDERR="$(mktemp)"
  if pt_cli "$@" >"$LAST_CAPTURE_STDOUT" 2>"$LAST_CAPTURE_STDERR"; then
    LAST_CAPTURE_STATUS=0
  else
    LAST_CAPTURE_STATUS=$?
  fi
  return 0
}

cleanup_capture() {
  [ -n "${LAST_CAPTURE_STDOUT:-}" ] && rm -f "$LAST_CAPTURE_STDOUT"
  [ -n "${LAST_CAPTURE_STDERR:-}" ] && rm -f "$LAST_CAPTURE_STDERR"
  LAST_CAPTURE_STDOUT=""
  LAST_CAPTURE_STDERR=""
  LAST_CAPTURE_STATUS=""
}

capture_json_message() {
  "$PYTHON_BIN" - "$LAST_CAPTURE_STDOUT" "$LAST_CAPTURE_STDERR" <<'PY'
from pathlib import Path
import json
import sys

stdout_path = Path(sys.argv[1])
stderr_path = Path(sys.argv[2])
text = stdout_path.read_text(encoding="utf-8", errors="replace").strip()
if text:
    try:
        payload = json.loads(text)
    except Exception:
        print(" ".join(text.split()))
        raise SystemExit(0)
    if isinstance(payload, dict):
        message = payload.get("message")
        if message:
            print(str(message))
            raise SystemExit(0)
stderr = stderr_path.read_text(encoding="utf-8", errors="replace").strip()
if stderr:
    print(" ".join(stderr.split()))
PY
}

capture_json_field() {
  "$PYTHON_BIN" - "$LAST_CAPTURE_STDOUT" "$1" <<'PY'
from pathlib import Path
import json
import sys

payload = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8", errors="replace"))
field = sys.argv[2]
value = payload.get(field, "")
if value is None:
    value = ""
print(str(value).replace("\n", " ").strip())
PY
}

debug_capture_if_enabled() {
  [ "$MENU_DEBUG" = "1" ] || return 0
  [ -n "${LAST_CAPTURE_STDOUT:-}" ] && [ -s "$LAST_CAPTURE_STDOUT" ] && cat "$LAST_CAPTURE_STDOUT"
  [ -n "${LAST_CAPTURE_STDERR:-}" ] && [ -s "$LAST_CAPTURE_STDERR" ] && cat "$LAST_CAPTURE_STDERR" >&2
}

apply_role_change() {
  role="$1"
  force_flag="$2"
  if [ "$force_flag" = "true" ]; then
    if ! run_cli_capture init --force --role "$role"; then
      message="$(capture_json_message)"
      debug_capture_if_enabled
      cleanup_capture
      error_line "${message:-Role reconfiguration failed.}"
      return 1
    fi
  else
    if ! run_cli_capture init --role "$role"; then
      message="$(capture_json_message)"
      debug_capture_if_enabled
      cleanup_capture
      error_line "${message:-Role initialization failed.}"
      return 1
    fi
  fi
  debug_capture_if_enabled
  cleanup_capture

  load_node_snapshot
  if [ -z "$NODE_PREFERRED_LAYER" ]; then
    if ! run_cli_capture layer select --layer layer4; then
      message="$(capture_json_message)"
      debug_capture_if_enabled
      cleanup_capture
      warning "${message:-Unable to select the default preferred layer.}"
      return 0
    fi
    debug_capture_if_enabled
    cleanup_capture
  fi
  return 0
}

save_node_setup_metadata() {
  export PT_NODE_ROLE="$1"
  export PT_NODE_DISPLAY_NAME="$2"
  export PT_NODE_INSTALL_ROOT="$3"
  export PT_NODE_STATE_DIRECTORY="$4"
  export PT_NODE_WORK_DIRECTORY="$5"
  export PT_NODE_ENDPOINT_ADDRESS="$6"
  export PT_NODE_NOTES="$7"

  (
    cd "$REPO_DIR" || exit 1
    "$PYTHON_BIN" - "$CONFIG_FILE" <<'PY'
import os
import sys
from pathlib import Path

from pilottunnel.config import load_config, save_config

config_path = Path(sys.argv[1])
config = load_config(config_path)
config.node.display_name = os.environ.get("PT_NODE_DISPLAY_NAME", "").strip()
config.node.install_root = os.environ.get("PT_NODE_INSTALL_ROOT", "").strip()
config.node.state_directory = os.environ.get("PT_NODE_STATE_DIRECTORY", "").strip()
config.node.work_directory = os.environ.get("PT_NODE_WORK_DIRECTORY", "").strip()
config.node.endpoint_address = os.environ.get("PT_NODE_ENDPOINT_ADDRESS", "").strip()
config.node.notes = os.environ.get("PT_NODE_NOTES", "").strip()
if config.node.normalized_role == "controller":
    config.node.managed_remote_endpoints = list(config.node.managed_remote_endpoints or [])
else:
    config.node.managed_remote_endpoints = list(config.node.managed_remote_endpoints or [])
save_config(config, config_path)
PY
  )
}

show_node_status_summary() {
  (
    cd "$REPO_DIR" || exit 1
    "$PYTHON_BIN" - "$CONFIG_FILE" <<'PY'
import sys
from pathlib import Path

from pilottunnel.node_role import node_status_payload
from pilottunnel.config import load_config

config_path = Path(sys.argv[1])
config = load_config(config_path)
payload = node_status_payload(config, str(config_path))
role = payload.get("normalized_role") or ""
role_label = {
    "controller": "Iran side / controller",
    "worker": "Kharej side / worker",
}.get(role, "not configured")
print(f"Side: {role_label}")
print(f"Initialized: {'yes' if payload.get('initialized') else 'no'}")
print(f"Node ID: {payload.get('node_id') or 'not assigned'}")
print(f"Detected local address: {payload.get('detected_local_address') or 'not detected'}")
link = payload.get("active_link") or {}
if link:
    pairing_state = link.get("pairing_state") or "not configured"
    next_action = link.get("next_action") or "not configured"
    if pairing_state == "awaiting_worker_import":
        next_action = (
            "Open Setup / Configure this server and choose Show / Export pairing code here, "
            "then choose Import pairing code on the worker server."
        )
    print(f"Remote address: {link.get('remote_address') or 'not configured'}")
    print(f"Iran user-facing port: {link.get('controller_user_facing_port') or 'not configured'}")
    print(f"Tunnel transport port: {link.get('transport_port') or 'not configured'}")
    print(f"Kharej service port: {link.get('worker_service_port') or 'not configured'}")
    print(f"Pairing state: {pairing_state}")
    print(f"Next action: {next_action}")
else:
    print(f"Link count: {payload.get('link_count', 0)}")
print(f"Config path: {payload.get('config_path')}")
print(f"Preferred layer: {payload.get('preferred_layer') or 'not selected'}")
print(f"Allowed actions: {len(payload.get('allowed_actions') or [])}")
print(f"Blocked actions: {len(payload.get('blocked_actions') or [])}")
PY
  )
}

show_binary_status_summary() {
  (
    cd "$REPO_DIR" || exit 1
    "$PYTHON_BIN" - "$CONFIG_FILE" "$STATE_FILE" "$WORK_DIR" <<'PY'
import sys
from pathlib import Path
from urllib.parse import urlparse

from pilottunnel.binary_readiness import build_binary_readiness_report
from pilottunnel.config import load_config
from pilottunnel.state import load_state

config = load_config(Path(sys.argv[1]))
state = load_state(Path(sys.argv[2]))
work_dir = Path(sys.argv[3])
manifest_ref = config.binary_resolution.provider_manifest
allow_host = config.binary_resolution.provider_allow_host or None
manifest_url = None
manifest_file = None

if manifest_ref:
    parsed = urlparse(manifest_ref)
    if parsed.scheme in {"http", "https"}:
        manifest_url = manifest_ref
    else:
        manifest_file = Path(manifest_ref)

if not manifest_url and not manifest_file:
    print("Binary readiness: warning")
    print("Provider manifest: not configured")
    print("Tip: run the installer with managed binaries or configure a provider manifest first.")
    raise SystemExit(0)

try:
    payload = build_binary_readiness_report(
        cache_root=work_dir,
        state=state,
        manifest_url=manifest_url,
        manifest_file=manifest_file,
        allow_provider_host=allow_host,
        require_all=True,
    )
except Exception as exc:
    print("Binary readiness: warning")
    print(f"Provider manifest check: {exc}")
    raise SystemExit(0)
required = payload.get("required_adapters") or []
verified = payload.get("verified_adapters") or []
missing = payload.get("missing_adapters") or []
print(f"Required binaries verified: {len(verified)}/{len(required)}")
if missing:
    print("Missing binaries: " + ", ".join(missing))
else:
    print("Missing binaries: none")
for item in payload.get("results") or []:
    if not item.get("required_for_v0_1"):
        continue
    status = "OK" if item.get("verified") else "missing"
    print(f"- {item.get('adapter')}: {status}")
PY
  )
}

show_readiness_summary() {
  run_cli_capture_allow_failure readiness report --json
  rendered="$("$PYTHON_BIN" - "$LAST_CAPTURE_STDOUT" "$LAST_CAPTURE_STDERR" "${LAST_CAPTURE_STATUS:-1}" <<'PY' 2>/dev/null
from pathlib import Path
import json
import sys

stdout_path = Path(sys.argv[1])
stderr_path = Path(sys.argv[2])
command_status = int(sys.argv[3])
stdout_text = stdout_path.read_text(encoding="utf-8", errors="replace").strip()
stderr_text = stderr_path.read_text(encoding="utf-8", errors="replace").strip()

def cleaned(text: str) -> str:
    return " ".join(text.split())

if not stdout_text:
    if stderr_text:
        print(cleaned(stderr_text))
    else:
        print("Unable to generate readiness report.")
    raise SystemExit(1)

try:
    payload = json.loads(stdout_text)
except Exception:
    print("Malformed readiness report from CLI.")
    raise SystemExit(1)

if not isinstance(payload, dict) or "readiness_level" not in payload:
    print("Malformed readiness report from CLI.")
    raise SystemExit(1)

def print_list(label: str, values: list[str]) -> None:
    if values:
        print(f"{label}:")
        for item in values[:5]:
            print(f"- {cleaned(str(item))}")
    else:
        print(f"{label}: none")

readiness_level = payload.get("readiness_level") or "unknown"
node_role = payload.get("node_role") or "not configured"
role_initialized = bool(payload.get("role_initialized"))
profile_exists = bool(payload.get("profile_exists"))
profile_name = payload.get("profile")
if profile_exists and profile_name:
    profile_state = f"selected ({profile_name})"
elif profile_exists:
    profile_state = "configured"
else:
    profile_state = "none"

print(f"Readiness level: {readiness_level}")
print(f"Initialized role: {node_role if role_initialized else 'not initialized'}")
print(f"Profile state: {profile_state}")
print_list("Blockers", [str(item) for item in (payload.get("blockers") or [])])
print_list("Warnings", [str(item) for item in (payload.get("warnings") or [])])
print_list("Recommended next steps", [str(item) for item in (payload.get("recommended_next_steps") or [])])

if command_status not in {0, 1}:
    raise SystemExit(1)
PY
)"
  render_status=$?
  debug_capture_if_enabled
  cleanup_capture
  if [ "$render_status" -ne 0 ]; then
    error_line "${rendered:-Unable to render readiness report.}"
    return 0
  fi
  printf '%s\n' "$rendered"
}

render_banner() {
  box_border
  box_blank
  box_line_center " ____  _ _       _   _____                    _ " "$TITLE$BOLD"
  box_line_center "|  _ \\(_) | ___ | |_|_   _|   _ _ __  _ __   | |" "$TITLE$BOLD"
  box_line_center "| |_) | | |/ _ \\| __| | || | | | '_ \\| '_ \\  | |" "$TITLE$BOLD"
  box_line_center "|  __/| | | (_) | |_  | || |_| | | | | | | | |_|" "$TITLE$BOLD"
  box_line_center "|_|   |_|_|\\___/ \\__| |_| \\__,_|_| |_|_| |_| (_)" "$TITLE$BOLD"
  box_blank
  box_line_center "Safety-first multi-layer tunnel management" "$ACCENT$BOLD"
  box_line_center "Setup, readiness, binaries, and guarded operations" "$DIM"
  box_rule
}

render_status_panel() {
  version_text="$1"
  load_node_snapshot
  box_line_left "PilotTunnel Menu" "$ACCENT$BOLD"
  box_line_left "Version: ${version_text}" "$VALUE_COLOR"
  box_line_left "Current role: ${NODE_ROLE_LABEL}" "$VALUE_COLOR"
  box_line_left "Node label: ${NODE_DISPLAY_NAME:-not set}" "$VALUE_COLOR"
  box_line_left "Install root: ${BASE_DIR}" "$VALUE_COLOR"
  box_border
}

show_header() {
  clear_screen
  render_banner
  render_status_panel "$(installed_version)"
}

section_heading() {
  printf '\n%b%s%b\n' "$ACCENT$BOLD" "$1" "$RESET"
  printf '%b%s%b\n' "$FRAME" "$(repeat_char "-" 60)" "$RESET"
}

pause_menu() {
  printf '\n%bPress Enter to return to the menu...%b' "$DIM" "$RESET"
  IFS= read -r _ || true
}

map_role_selection() {
  case "$1" in
    1|controller) printf '%s\n' "controller" ;;
    2|worker) printf '%s\n' "worker" ;;
    *) return 1 ;;
  esac
}

prompt_with_default() {
  prompt_label="$1"
  default_value="$2"
  if [ -n "$default_value" ]; then
    printf '%b%s%b [%s]: ' "$PROMPT_COLOR$BOLD" "$prompt_label" "$RESET" "$default_value"
  else
    printf '%b%s%b: ' "$PROMPT_COLOR$BOLD" "$prompt_label" "$RESET"
  fi
  IFS= read -r input_value || return 1
  input_value="$(normalize_input "$input_value")"
  if [ -n "$input_value" ]; then
    PROMPT_RESULT="$input_value"
  else
    PROMPT_RESULT="$default_value"
  fi
}

prompt_sensitive_text() {
  prompt_label="$1"
  default_value="$2"
  if [ -t 0 ] && [ -t 1 ] && command -v stty >/dev/null 2>&1; then
    if [ -n "$default_value" ]; then
      printf '%b%s%b [%s]: ' "$PROMPT_COLOR$BOLD" "$prompt_label" "$RESET" "$default_value"
    else
      printf '%b%s%b: ' "$PROMPT_COLOR$BOLD" "$prompt_label" "$RESET"
    fi
    old_stty="$(stty -g 2>/dev/null || true)"
    stty -echo 2>/dev/null || true
    IFS= read -r input_value || {
      if [ -n "$old_stty" ]; then
        stty "$old_stty" 2>/dev/null || true
      else
        stty echo 2>/dev/null || true
      fi
      printf '\n'
      return 1
    }
    if [ -n "$old_stty" ]; then
      stty "$old_stty" 2>/dev/null || true
    else
      stty echo 2>/dev/null || true
    fi
    printf '\n'
    input_value="$(normalize_input "$input_value")"
    if [ -n "$input_value" ]; then
      PROMPT_RESULT="$input_value"
    else
      PROMPT_RESULT="$default_value"
    fi
    return 0
  fi
  prompt_with_default "$prompt_label" "$default_value"
}

show_setup_summary() {
  role_value="$1"
  pairing_code="${2:-}"
  load_link_snapshot
  show_header
  section_heading "Setup complete"
  printf '%bSide: %s%b\n' "$SUCCESS_COLOR$BOLD" "${CURRENT_LOCAL_SIDE:-$(role_label "$role_value")}" "$RESET"
  printf '%bDetected local address: %s%b\n' "$SUCCESS_COLOR$BOLD" "${CURRENT_LOCAL_ADDRESS:-not detected}" "$RESET"
  printf '%bRemote address: %s%b\n' "$SUCCESS_COLOR$BOLD" "${CURRENT_REMOTE_ADDRESS:-not configured}" "$RESET"
  printf '%bIran user-facing port: %s%b\n' "$SUCCESS_COLOR$BOLD" "${CURRENT_IRAN_MAIN_PORT:-not configured}" "$RESET"
  printf '%bTunnel transport port: %s%b\n' "$SUCCESS_COLOR$BOLD" "${CURRENT_TUNNEL_PORT:-not configured}" "$RESET"
  printf '%bKharej service port: %s%b\n' "$SUCCESS_COLOR$BOLD" "${CURRENT_CONFIG_PORT:-not configured}" "$RESET"
  printf '%bPairing state: %s%b\n' "$SUCCESS_COLOR$BOLD" "${CURRENT_PAIRING_STATE:-not configured}" "$RESET"
  if [ -n "$pairing_code" ]; then
    printf '\n%bSensitive pairing code (controller -> worker transfer only):%b\n%s\n' "$WARN_COLOR$BOLD" "$RESET" "$pairing_code"
    printf '%bWorker import path:%b Setup / Configure this server -> Import pairing code\n' "$ACCENT$BOLD" "$RESET"
  elif [ -n "$CURRENT_NEXT_ACTION" ]; then
    printf '%bNext:%b %s\n' "$ACCENT$BOLD" "$RESET" "$(menu_next_action_message "$role_value" "$CURRENT_PAIRING_STATE" "$CURRENT_NEXT_ACTION")"
  fi

  binary_summary="$(show_binary_status_summary)"
  if printf '%s\n' "$binary_summary" | grep -qi "Missing binaries: none"; then
    printf '%bBinary readiness:%b OK\n' "$VALUE_COLOR$BOLD" "$RESET"
  else
    printf '%bBinary readiness:%b warning\n' "$VALUE_COLOR$BOLD" "$RESET"
  fi
  printf '\n%s\n' "$binary_summary"
}

show_current_setup_panel() {
  printf '%bCurrent setup:%b\n' "$VALUE_COLOR$BOLD" "$RESET"
  printf 'Side: %s\n' "${CURRENT_LOCAL_SIDE:-$NODE_ROLE_LABEL}"
  if [ -n "$CURRENT_LINK_LABEL" ]; then
    printf 'Link label: %s\n' "$CURRENT_LINK_LABEL"
    printf 'Detected local address: %s\n' "${CURRENT_LOCAL_ADDRESS:-not detected}"
    printf 'Remote address: %s\n' "${CURRENT_REMOTE_ADDRESS:-not configured}"
    printf 'Iran user-facing port: %s\n' "${CURRENT_IRAN_MAIN_PORT:-not configured}"
    printf 'Tunnel transport port: %s\n' "${CURRENT_TUNNEL_PORT:-not configured}"
    printf 'Kharej service port: %s\n' "${CURRENT_CONFIG_PORT:-not configured}"
    printf 'Pairing state: %s\n' "${CURRENT_PAIRING_STATE:-not configured}"
  else
    printf 'Link label: not configured\n'
  fi
}

prompt_required_text() {
  prompt_label="$1"
  default_value="$2"
  while true; do
    prompt_with_default "$prompt_label" "$default_value" || return 1
    candidate="$(printf '%s' "$PROMPT_RESULT" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    if [ -n "$candidate" ]; then
      PROMPT_RESULT="$candidate"
      return 0
    fi
    warning "$prompt_label is required."
  done
}

prompt_sensitive_required_text() {
  prompt_label="$1"
  default_value="$2"
  while true; do
    prompt_sensitive_text "$prompt_label" "$default_value" || return 1
    candidate="$(printf '%s' "$PROMPT_RESULT" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    if [ -n "$candidate" ]; then
      PROMPT_RESULT="$candidate"
      return 0
    fi
    warning "$prompt_label is required."
  done
}

clear_pairing_code_input() {
  pairing_code_input=""
  PROMPT_RESULT=""
  unset pairing_code_input
  unset PROMPT_RESULT
}

prompt_pairing_code_input() {
  while true; do
    show_header
    section_heading "Import pairing code"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "1. Visible paste (recommended for browser/web terminals)" "$RESET"
    menu_hint "   The code will be visible on screen temporarily while you paste it."
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "2. Hidden paste" "$RESET"
    menu_hint "   Use this only when your terminal supports hidden input pasting correctly."
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "3. Cancel" "$RESET"
    printf '\n'
    prompt_input
    IFS= read -r pairing_input_mode || return 1
    pairing_input_mode="$(normalize_input "$pairing_input_mode")"
    case "$pairing_input_mode" in
      1)
        warning "Visible paste mode will temporarily show the pairing code on screen."
        printf '\n'
        prompt_required_text "Paste pairing code" "" || return 1
        pairing_code_input="$PROMPT_RESULT"
        PROMPT_RESULT=""
        return 0
        ;;
      2)
        prompt_sensitive_required_text "Paste pairing code" "" || return 1
        pairing_code_input="$PROMPT_RESULT"
        PROMPT_RESULT=""
        return 0
        ;;
      3)
        clear_pairing_code_input
        return 2
        ;;
      *)
        warning "Enter a number from 1 to 3."
        pause_menu
        ;;
    esac
  done
}

menu_next_action_message() {
  role_value="$1"
  pairing_state="$2"
  fallback_message="$3"
  case "$pairing_state" in
    awaiting_worker_import)
      if [ "$role_value" = "controller" ]; then
        printf '%s\n' "Use Setup / Configure this server -> Show / Export pairing code here, then choose Import pairing code on the worker server."
      else
        printf '%s\n' "Choose Setup / Configure this server -> Import pairing code on the worker server."
      fi
      ;;
    *)
      printf '%s\n' "$fallback_message"
      ;;
  esac
}

export_pairing_code_screen() {
  role_value="$1"
  if ! run_cli_capture link export-pairing-code --label "$CURRENT_LINK_LABEL"; then
    message="$(capture_json_message)"
    cleanup_capture
    warning "${message:-Unable to export the pairing code.}"
    pause_menu
    return 1
  fi
  pairing_code="$(capture_json_field pairing_code)"
  cleanup_capture
  show_setup_summary "$role_value" "$pairing_code"
  return 0
}

prompt_port_value() {
  prompt_label="$1"
  default_value="$2"
  while true; do
    prompt_with_default "$prompt_label" "$default_value" || return 1
    candidate="$(printf '%s' "$PROMPT_RESULT" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    if printf '%s' "$candidate" | grep -Eq '^[0-9]+$' && [ "$candidate" -ge 1 ] && [ "$candidate" -le 65535 ]; then
      PROMPT_RESULT="$candidate"
      return 0
    fi
    warning "$prompt_label must be an integer between 1 and 65535."
  done
}

prompt_optional_label_value() {
  prompt_label="$1"
  default_value="$2"
  while true; do
    prompt_with_default "$prompt_label" "$default_value" || return 1
    candidate="$(printf '%s' "$PROMPT_RESULT" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    if [ -z "$candidate" ]; then
      PROMPT_RESULT=""
      return 0
    fi
    if printf '%s' "$candidate" | grep -Eq '^[A-Za-z0-9_-]+$'; then
      PROMPT_RESULT="$candidate"
      return 0
    fi
    warning "Link label may contain only letters, numbers, dashes, and underscores."
  done
}

select_role_for_setup() {
  while true; do
    show_header
    section_heading "Setup / Configure this server"
    load_link_snapshot
    if [ "$NODE_INITIALIZED" = "true" ]; then
      show_current_setup_panel
      can_export_pairing="false"
      if [ "$NODE_ROLE" = "controller" ] && [ -n "$CURRENT_LINK_LABEL" ] && [ "$CURRENT_PAIRING_STATE" = "awaiting_worker_import" ]; then
        can_export_pairing="true"
      fi
      printf '\n%b%s%b\n' "$VALUE_COLOR$BOLD" "1. Keep current setup" "$RESET"
      if [ "$can_export_pairing" = "true" ]; then
        printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "2. Show / Export pairing code" "$RESET"
        printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "3. Reconfigure setup" "$RESET"
        printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "4. Back" "$RESET"
      else
        printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "2. Reconfigure setup" "$RESET"
        printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "3. Back" "$RESET"
      fi
      printf '\n'
      prompt_input
      IFS= read -r current_selection || return 1
      current_selection="$(normalize_input "$current_selection")"
      if [ "$can_export_pairing" = "true" ]; then
        case "$current_selection" in
          1)
            SELECTED_ROLE="$NODE_ROLE"
            ROLE_CHANGE_MODE="keep"
            return 0
            ;;
          2)
            SELECTED_ROLE="$NODE_ROLE"
            ROLE_CHANGE_MODE="export_pairing"
            return 0
            ;;
          3)
            ROLE_CHANGE_MODE="reconfigure"
            ;;
          4) return 1 ;;
          *) warning "Enter a number from 1 to 4."; pause_menu; continue ;;
        esac
      else
        case "$current_selection" in
          1)
            SELECTED_ROLE="$NODE_ROLE"
            ROLE_CHANGE_MODE="keep"
            return 0
            ;;
          2)
            ROLE_CHANGE_MODE="reconfigure"
            ;;
          3) return 1 ;;
          *) warning "Enter a number from 1 to 3."; pause_menu; continue ;;
        esac
      fi
    else
      printf '%bCurrent state:%b not configured\n' "$VALUE_COLOR$BOLD" "$RESET"
      ROLE_CHANGE_MODE="new"
    fi

    show_header
    section_heading "Choose the side for this server"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "1. Iran / Controller" "$RESET"
    menu_hint "   Decision-maker side. This side creates the link and pairing code first."
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "2. Kharej / Worker" "$RESET"
    menu_hint "   Remote endpoint side. This side imports the pairing code or uses manual fallback."
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "3. Back" "$RESET"
    prompt_input
    IFS= read -r selection || return 1
    selection="$(normalize_input "$selection")"
    case "$selection" in
      1|2)
        if SELECTED_ROLE="$(map_role_selection "$selection")"; then
          return 0
        fi
        ;;
      3) return 1 ;;
      *) warning "Enter 1, 2, or 3."; pause_menu ;;
    esac
  done
}

run_setup_wizard() {
  load_node_snapshot
  load_link_snapshot
  if ! select_role_for_setup; then
    return
  fi

  if [ "$ROLE_CHANGE_MODE" = "export_pairing" ] && [ -n "$CURRENT_LINK_LABEL" ]; then
    export_pairing_code_screen "$SELECTED_ROLE"
    return
  fi

  if [ "$ROLE_CHANGE_MODE" = "keep" ] && [ -n "$CURRENT_LINK_LABEL" ]; then
    show_setup_summary "$SELECTED_ROLE"
    return
  fi

  role_mode="$ROLE_CHANGE_MODE"
  while true; do
    if [ "$role_mode" = "new" ]; then
      apply_role_change "$SELECTED_ROLE" "false" || return
      role_mode="configured"
    elif [ "$role_mode" = "reconfigure" ]; then
      apply_role_change "$SELECTED_ROLE" "true" || return
      role_mode="configured"
    fi

    if [ "$SELECTED_ROLE" = "controller" ]; then
      show_header
      section_heading "Controller pairing setup"
      menu_hint "Create the link on the Iran/controller side first, then export one pairing code for the Kharej/worker side."
      prompt_required_text "Kharej public IP / domain" "$CURRENT_REMOTE_ADDRESS" || return
      worker_address="$PROMPT_RESULT"
      printf '\n'
      prompt_port_value "Kharej VPN service/config port" "$CURRENT_CONFIG_PORT" || return
      service_port="$PROMPT_RESULT"
      printf '\n'
      prompt_port_value "Tunnel transport port between the servers" "$CURRENT_TUNNEL_PORT" || return
      transport_port="$PROMPT_RESULT"
      printf '\n'
      prompt_port_value "Iran user-facing port" "${CURRENT_IRAN_MAIN_PORT:-$service_port}" || return
      user_facing_port="$PROMPT_RESULT"
      printf '\n'

      cli_args=(link create-controller --worker-address "$worker_address" --service-port "$service_port" --transport-port "$transport_port" --user-facing-port "$user_facing_port")
      if [ "$role_mode" != "new" ] && [ -n "$CURRENT_LINK_LABEL" ]; then
        cli_args+=(--replace-label "$CURRENT_LINK_LABEL")
      fi
      if ! run_cli_capture "${cli_args[@]}"; then
        message="$(capture_json_message)"
        debug_capture_if_enabled
        cleanup_capture
        warning "${message:-Unable to create the controller link. Please try again.}"
        pause_menu
        continue
      fi
      debug_capture_if_enabled
      cleanup_capture
      load_node_snapshot
      load_link_snapshot

      export_pairing_code_screen "$SELECTED_ROLE" || return
      return
    fi

    show_header
    section_heading "Worker pairing setup"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "1. Import pairing code (recommended)" "$RESET"
    menu_hint "   Paste the ptlink code generated on the Iran/controller server."
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "2. Manual setup" "$RESET"
    menu_hint "   Use this only if pairing code import is not available yet."
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "3. Back" "$RESET"
    printf '\n'
    prompt_input
    IFS= read -r worker_mode || return
    worker_mode="$(normalize_input "$worker_mode")"
    case "$worker_mode" in
      1)
        prompt_pairing_code_input
        prompt_status=$?
        if [ "$prompt_status" -eq 2 ]; then
          continue
        elif [ "$prompt_status" -ne 0 ]; then
          clear_pairing_code_input
          return
        fi
        if [ "$role_mode" != "new" ] && [ -n "$CURRENT_LINK_LABEL" ]; then
          replace_link_label="$CURRENT_LINK_LABEL"
        else
          replace_link_label=""
        fi
        if [ -n "$replace_link_label" ]; then
          if ! run_cli_capture link import-pairing-code --code "$pairing_code_input" --replace-label "$replace_link_label"; then
            import_failed="true"
          else
            import_failed="false"
          fi
        else
          if ! run_cli_capture link import-pairing-code --code "$pairing_code_input"; then
            import_failed="true"
          else
            import_failed="false"
          fi
        fi
        if [ "$import_failed" = "true" ]; then
          message="$(capture_json_message)"
          if printf '%s' "$message" | grep -q -- "--confirm-address-mismatch"; then
            warning "$message"
            printf '%bContinue and accept this address mismatch? [y/N]:%b ' "$WARN_COLOR$BOLD" "$RESET"
            IFS= read -r mismatch_answer || {
              clear_pairing_code_input
              return
            }
            mismatch_answer="$(normalize_input "$mismatch_answer")"
            case "$mismatch_answer" in
              y|Y|yes|YES)
                if [ -n "$replace_link_label" ]; then
                  if ! run_cli_capture link import-pairing-code --code "$pairing_code_input" --replace-label "$replace_link_label" --confirm-address-mismatch; then
                    confirm_failed="true"
                  else
                    confirm_failed="false"
                  fi
                else
                  if ! run_cli_capture link import-pairing-code --code "$pairing_code_input" --confirm-address-mismatch; then
                    confirm_failed="true"
                  else
                    confirm_failed="false"
                  fi
                fi
                if [ "$confirm_failed" = "true" ]; then
                  message="$(capture_json_message)"
                  clear_pairing_code_input
                  debug_capture_if_enabled
                  cleanup_capture
                  warning "${message:-Unable to import the pairing code.}"
                  pause_menu
                  continue
                fi
                ;;
              *)
                clear_pairing_code_input
                cleanup_capture
                warning "Pairing import cancelled."
                pause_menu
                continue
                ;;
            esac
          else
            clear_pairing_code_input
            debug_capture_if_enabled
            cleanup_capture
            warning "${message:-Unable to import the pairing code.}"
            pause_menu
            continue
          fi
        fi
        clear_pairing_code_input
        debug_capture_if_enabled
        cleanup_capture
        load_node_snapshot
        load_link_snapshot
        show_setup_summary "$SELECTED_ROLE"
        return
        ;;
      2)
        prompt_required_text "Iran/controller IP / domain" "$CURRENT_REMOTE_ADDRESS" || return
        controller_address="$PROMPT_RESULT"
        printf '\n'
        prompt_port_value "Tunnel transport port between the servers" "$CURRENT_TUNNEL_PORT" || return
        transport_port="$PROMPT_RESULT"
        printf '\n'
        prompt_port_value "Local VPN service/config port" "$CURRENT_CONFIG_PORT" || return
        service_port="$PROMPT_RESULT"
        printf '\n'
        cli_args=(link setup-worker-manual --controller-address "$controller_address" --transport-port "$transport_port" --service-port "$service_port")
        if [ "$role_mode" != "new" ] && [ -n "$CURRENT_LINK_LABEL" ]; then
          cli_args+=(--replace-label "$CURRENT_LINK_LABEL")
        fi
        if ! run_cli_capture "${cli_args[@]}"; then
          message="$(capture_json_message)"
          debug_capture_if_enabled
          cleanup_capture
          warning "${message:-Unable to save manual worker setup.}"
          pause_menu
          continue
        fi
        debug_capture_if_enabled
        cleanup_capture
        load_node_snapshot
        load_link_snapshot
        show_setup_summary "$SELECTED_ROLE"
        return
        ;;
      3) return ;;
      *)
        warning "Enter a number from 1 to 3."
        pause_menu
        ;;
    esac
  done
}

show_status() {
  show_header
  section_heading "Node status"
  show_node_status_summary
}

show_readiness() {
  show_header
  section_heading "Readiness report"
  show_readiness_summary
}

show_binary_status() {
  show_header
  section_heading "Binary status"
  show_binary_status_summary
}

prompt_candidate_adapter() {
  printf '%bAdapter:%b ' "$PROMPT_COLOR$BOLD" "$RESET"
  IFS= read -r CANDIDATE_ADAPTER || return 1
  CANDIDATE_ADAPTER="$(normalize_input "$CANDIDATE_ADAPTER")"
  [ -n "$CANDIDATE_ADAPTER" ] || {
    warning "Adapter is required."
    return 1
  }
}

candidate_prepare_all() {
  section_heading "Prepare all candidates"
  pt_cli candidate prepare-all
}

candidate_plan() {
  prompt_candidate_adapter || return
  section_heading "Candidate plan"
  pt_cli candidate plan --adapter "$CANDIDATE_ADAPTER"
}

candidate_start() {
  prompt_candidate_adapter || return
  section_heading "Candidate start"
  pt_cli candidate start --adapter "$CANDIDATE_ADAPTER"
}

candidate_stop() {
  section_heading "Candidate stop"
  pt_cli candidate stop
}

candidate_smoke_test() {
  prompt_candidate_adapter || return
  section_heading "Candidate smoke test"
  pt_cli candidate smoke-test --adapter "$CANDIDATE_ADAPTER"
}

candidate_results() {
  section_heading "Candidate results"
  pt_cli candidate result
}

candidate_testing_menu() {
  while true; do
    show_header
    section_heading "Candidate Testing"
    if [ "$NODE_ROLE" = "worker" ]; then
      printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "1. Prepare all candidates" "$RESET"
      printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "2. Show candidate plans" "$RESET"
      printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "3. Start selected candidate" "$RESET"
      printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "4. Stop current candidate" "$RESET"
      printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "5. Show results" "$RESET"
      printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "6. Back" "$RESET"
      printf '\n'
      menu_hint "Manual workflow: prepare -> start the selected worker-side candidate -> wait for the controller smoke test."
      prompt_input
      IFS= read -r selection || return
      selection="$(normalize_input "$selection")"
      case "$selection" in
        1) candidate_prepare_all; pause_menu ;;
        2) candidate_plan; pause_menu ;;
        3) candidate_start; pause_menu ;;
        4) candidate_stop; pause_menu ;;
        5) candidate_results; pause_menu ;;
        6) return ;;
        *) warning "Enter a number from 1 to 6."; pause_menu ;;
      esac
    else
      printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "1. Prepare all candidates" "$RESET"
      printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "2. Show candidate plans" "$RESET"
      printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "3. Start selected candidate" "$RESET"
      printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "4. Run real smoke test" "$RESET"
      printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "5. Stop current candidate" "$RESET"
      printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "6. Show comparison" "$RESET"
      printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "7. Back" "$RESET"
      printf '\n'
      menu_hint "Manual workflow: prepare -> start the controller side when required -> start the worker side -> run the controller smoke test."
      prompt_input
      IFS= read -r selection || return
      selection="$(normalize_input "$selection")"
      case "$selection" in
        1) candidate_prepare_all; pause_menu ;;
        2) candidate_plan; pause_menu ;;
        3) candidate_start; pause_menu ;;
        4) candidate_smoke_test; pause_menu ;;
        5) candidate_stop; pause_menu ;;
        6) candidate_results; pause_menu ;;
        7) return ;;
        *) warning "Enter a number from 1 to 7."; pause_menu ;;
      esac
    fi
  done
}

prompt_service_identity() {
  printf '%bProfile:%b ' "$PROMPT_COLOR$BOLD" "$RESET"
  IFS= read -r SERVICE_PROFILE || return 1
  SERVICE_PROFILE="$(normalize_input "$SERVICE_PROFILE")"
  printf '%bAdapter:%b ' "$PROMPT_COLOR$BOLD" "$RESET"
  IFS= read -r SERVICE_ADAPTER || return 1
  SERVICE_ADAPTER="$(normalize_input "$SERVICE_ADAPTER")"
  printf '%bTransport:%b ' "$PROMPT_COLOR$BOLD" "$RESET"
  IFS= read -r SERVICE_TRANSPORT || return 1
  SERVICE_TRANSPORT="$(normalize_input "$SERVICE_TRANSPORT")"
  [ -n "$SERVICE_PROFILE" ] && [ -n "$SERVICE_ADAPTER" ] && [ -n "$SERVICE_TRANSPORT" ] || {
    warning "Profile, adapter, and transport are required."
    return 1
  }
}

prompt_service_action() {
  printf '%bAction (start/stop/restart/enable/disable):%b ' "$PROMPT_COLOR$BOLD" "$RESET"
  IFS= read -r SERVICE_ACTION || return 1
  SERVICE_ACTION="$(normalize_input "$SERVICE_ACTION")"
  case "$SERVICE_ACTION" in
    start) SERVICE_CONFIRM_TOKEN="START_SERVICE" ;;
    stop) SERVICE_CONFIRM_TOKEN="STOP_SERVICE" ;;
    restart) SERVICE_CONFIRM_TOKEN="RESTART_SERVICE" ;;
    enable) SERVICE_CONFIRM_TOKEN="ENABLE_SERVICE" ;;
    disable) SERVICE_CONFIRM_TOKEN="DISABLE_SERVICE" ;;
    *) warning "Unsupported service action."; return 1 ;;
  esac
}

service_plan() {
  prompt_service_identity || return
  prompt_service_action || return
  section_heading "Service plan"
  pt_cli service plan \
    --profile "$SERVICE_PROFILE" \
    --adapter "$SERVICE_ADAPTER" \
    --transport "$SERVICE_TRANSPORT" \
    --action "$SERVICE_ACTION"
}

service_status() {
  prompt_service_identity || return
  section_heading "Read-only service status"
  pt_cli service status \
    --profile "$SERVICE_PROFILE" \
    --adapter "$SERVICE_ADAPTER" \
    --transport "$SERVICE_TRANSPORT" \
    --real-systemd
}

service_apply() {
  prompt_service_identity || return
  prompt_service_action || return
  section_heading "Service plan"
  pt_cli service plan \
    --profile "$SERVICE_PROFILE" \
    --adapter "$SERVICE_ADAPTER" \
    --transport "$SERVICE_TRANSPORT" \
    --action "$SERVICE_ACTION" || return
  printf '\n%bType %s to apply this action:%b ' "$WARN_COLOR$BOLD" "$SERVICE_CONFIRM_TOKEN" "$RESET"
  IFS= read -r confirmation || return
  confirmation="$(normalize_input "$confirmation")"
  if [ "$confirmation" != "$SERVICE_CONFIRM_TOKEN" ]; then
    warning "Service action cancelled."
    return
  fi
  pt_cli service "$SERVICE_ACTION" \
    --profile "$SERVICE_PROFILE" \
    --adapter "$SERVICE_ADAPTER" \
    --transport "$SERVICE_TRANSPORT" \
    --real-systemd \
    --confirm "$SERVICE_CONFIRM_TOKEN"
}

service_menu() {
  while true; do
    show_header
    section_heading "Service management"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "1. Read-only service status" "$RESET"
    menu_hint "   Inspect managed service state without changing it."
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "2. Plan an action" "$RESET"
    menu_hint "   Preview a guarded service operation."
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "3. Apply a guarded action" "$RESET"
    menu_hint "   Confirmation is always required for live service operations."
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "4. Back" "$RESET"
    printf '\n'
    menu_hint "Safety: no service action runs without confirmation."
    prompt_input
    IFS= read -r selection || return
    selection="$(normalize_input "$selection")"
    case "$selection" in
      1) service_status; pause_menu ;;
      2) service_plan; pause_menu ;;
      3) service_apply; pause_menu ;;
      4) return ;;
      *) warning "Enter a number from 1 to 4."; pause_menu ;;
    esac
  done
}

backup_restore_menu() {
  while true; do
    show_header
    section_heading "Backup / Restore"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "1. List backups" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "2. Create a guarded backup" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "3. Plan a restore" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "4. Apply a guarded restore" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "5. Back" "$RESET"
    printf '\n'
    menu_hint "Safety: restore remains confirmation-gated."
    prompt_input
    IFS= read -r selection || return
    selection="$(normalize_input "$selection")"
    case "$selection" in
      1) section_heading "Backup list"; pt_cli backup list; pause_menu ;;
      2)
        section_heading "Backup plan"
        pt_cli backup plan || { pause_menu; continue; }
        printf '\n%bType BACKUP_CREATE to create the backup:%b ' "$WARN_COLOR$BOLD" "$RESET"
        IFS= read -r confirmation || return
        confirmation="$(normalize_input "$confirmation")"
        [ "$confirmation" = "BACKUP_CREATE" ] && pt_cli backup create --confirm BACKUP_CREATE || warning "Backup cancelled."
        pause_menu
        ;;
      3)
        printf '%bBackup ID:%b ' "$PROMPT_COLOR$BOLD" "$RESET"
        IFS= read -r backup_id || return
        backup_id="$(normalize_input "$backup_id")"
        section_heading "Restore plan"
        pt_cli restore plan --backup-id "$backup_id"
        pause_menu
        ;;
      4)
        printf '%bBackup ID:%b ' "$PROMPT_COLOR$BOLD" "$RESET"
        IFS= read -r backup_id || return
        backup_id="$(normalize_input "$backup_id")"
        section_heading "Restore plan"
        pt_cli restore plan --backup-id "$backup_id" || { pause_menu; continue; }
        printf '\n%bType RESTORE_APPLY to restore this backup:%b ' "$WARN_COLOR$BOLD" "$RESET"
        IFS= read -r confirmation || return
        confirmation="$(normalize_input "$confirmation")"
        [ "$confirmation" = "RESTORE_APPLY" ] && pt_cli restore apply --backup-id "$backup_id" --confirm RESTORE_APPLY || warning "Restore cancelled."
        pause_menu
        ;;
      5) return ;;
      *) warning "Enter a number from 1 to 5."; pause_menu ;;
    esac
  done
}

main_menu() {
  while true; do
    show_header
    printf '\n%b%s%b\n' "$ACCENT$BOLD" "Choose an action" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "1. Setup / Configure this server" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "2. Status" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "3. Readiness report" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "4. Binary status" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "5. Candidate Testing" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "6. Service management" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "7. Backup / Restore" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "8. Exit" "$RESET"
    printf '\n'
    menu_hint "Select an option and press Enter."
    menu_hint "Safety: no service action runs without confirmation."
    prompt_input
    IFS= read -r selection || return
    selection="$(normalize_input "$selection")"
    case "$selection" in
      1) run_setup_wizard; pause_menu ;;
      2) show_status; pause_menu ;;
      3) show_readiness; pause_menu ;;
      4) show_binary_status; pause_menu ;;
      5) candidate_testing_menu ;;
      6) service_menu ;;
      7) backup_restore_menu ;;
      8) success "Goodbye."; return ;;
      *) warning "Enter a number from 1 to 8."; pause_menu ;;
    esac
  done
}

main() {
  parse_args "$@"
  init_theme
  PYTHON_BIN="$(find_python)"
  [ -n "$PYTHON_BIN" ] || fail "Python is required but was not found."
  prepare_paths
  if [ "${PILOTTUNNEL_MENU_ALLOW_NON_TTY:-0}" != "1" ]; then
    [ -t 0 ] && [ -t 1 ] || fail "PilotTunnel Menu requires an interactive terminal."
  fi
  main_menu
}

if [ "${BASH_SOURCE[0]}" = "$0" ]; then
  main "$@"
fi
