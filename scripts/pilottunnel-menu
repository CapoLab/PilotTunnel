#!/usr/bin/env bash
set -uo pipefail

DEFAULT_BASE_DIR="/opt/pilottunnel"
BASE_DIR="$DEFAULT_BASE_DIR"
PYTHON_BIN=""
TERM_WIDTH=88
PANEL_WIDTH=80
MENU_DEBUG="${PILOTTUNNEL_MENU_DEBUG:-0}"

RESET=""
BOLD=""
DIM=""
FRAME=""
TITLE=""
ACCENT=""
INFO_COLOR=""
SUCCESS_COLOR=""
WARN_COLOR=""
ERROR_COLOR=""
VALUE_COLOR=""
PROMPT_COLOR=""

NODE_INITIALIZED="false"
NODE_ROLE=""
NODE_ROLE_LABEL="not configured"
NODE_DISPLAY_NAME=""
NODE_INSTALL_ROOT=""
NODE_STATE_DIRECTORY=""
NODE_WORK_DIRECTORY=""
NODE_ENDPOINT_ADDRESS=""
NODE_NOTES=""
NODE_ID=""
NODE_CONFIG_PATH=""
NODE_PREFERRED_LAYER=""
NODE_MANAGED_ENDPOINT_COUNT="0"
CURRENT_LINK_COUNT="0"
CURRENT_LINK_LABEL=""
CURRENT_IRAN_ADDRESS=""
CURRENT_IRAN_MAIN_PORT=""
CURRENT_TUNNEL_PORT=""
CURRENT_CONFIG_PORT=""
CURRENT_KHAREJ_ADDRESS=""
CURRENT_LINK_STATUS=""

fail() {
  printf '%s\n' "Error: $*" >&2
  exit 1
}

usage() {
  cat <<EOF
PilotTunnel terminal menu

Usage:
  pilottunnel-menu [--base-dir <DIR>]

Options:
  --base-dir <DIR>  PilotTunnel installation root. Defaults to ${DEFAULT_BASE_DIR}.
  --help            Show this help text.
EOF
}

parse_args() {
  while [ $# -gt 0 ]; do
    case "$1" in
      --base-dir) [ $# -ge 2 ] || fail "--base-dir requires a value"; BASE_DIR="$2"; shift 2 ;;
      --help|-h) usage; exit 0 ;;
      *) fail "Unknown argument: $1" ;;
    esac
  done
}

find_python() {
  if command -v python3 >/dev/null 2>&1; then
    printf '%s\n' "python3"
  elif command -v python >/dev/null 2>&1; then
    printf '%s\n' "python"
  else
    printf '%s\n' ""
  fi
}

prepare_paths() {
  case "$BASE_DIR" in
    /*) ;;
    *) BASE_DIR="$(cd "$BASE_DIR" 2>/dev/null && pwd -P)" || fail "Base directory does not exist: $BASE_DIR" ;;
  esac
  REPO_DIR="${BASE_DIR}/repo"
  STATE_DIR="${BASE_DIR}/state"
  WORK_DIR="${BASE_DIR}/work"
  STAGING_ROOT="${BASE_DIR}/staging"
  INSTALL_ROOT="${BASE_DIR}/install-root"
  CONFIG_FILE="${STATE_DIR}/config.json"
  STATE_FILE="${STATE_DIR}/state.json"
  REGISTRY_FILE="${STATE_DIR}/registry.json"
  AUDIT_LOG="${STATE_DIR}/audit.log"
  LOCK_DIR="${STATE_DIR}/locks"
  [ -d "$REPO_DIR/pilottunnel" ] || fail "PilotTunnel repository is not installed under $REPO_DIR"
}

pt_cli() {
  (
    cd "$REPO_DIR" || exit 1
    "$PYTHON_BIN" -m pilottunnel.cli \
      --config "$CONFIG_FILE" \
      --state "$STATE_FILE" \
      --registry "$REGISTRY_FILE" \
      --audit-log "$AUDIT_LOG" \
      --lock-dir "$LOCK_DIR" \
      --work-dir "$WORK_DIR" \
      --staging-root "$STAGING_ROOT" \
      "$@"
  )
}

init_theme() {
  if [ "${NO_COLOR:-}" = "" ] && { [ -t 1 ] || [ "${PILOTTUNNEL_MENU_ALLOW_NON_TTY:-0}" = "1" ]; }; then
    ESC="$(printf '\033')"
    RESET="${ESC}[0m"
    BOLD="${ESC}[1m"
    DIM="${ESC}[2m"
    FRAME="${ESC}[38;5;81m"
    TITLE="${ESC}[38;5;51m"
    ACCENT="${ESC}[38;5;226m"
    INFO_COLOR="${ESC}[38;5;117m"
    SUCCESS_COLOR="${ESC}[38;5;84m"
    WARN_COLOR="${ESC}[38;5;214m"
    ERROR_COLOR="${ESC}[38;5;203m"
    VALUE_COLOR="${ESC}[38;5;195m"
    PROMPT_COLOR="${ESC}[38;5;159m"
  fi

  if command -v tput >/dev/null 2>&1; then
    detected_width="$(tput cols 2>/dev/null || printf '%s\n' 88)"
  else
    detected_width=88
  fi
  case "$detected_width" in
    ''|*[!0-9]*) detected_width=88 ;;
  esac
  TERM_WIDTH="$detected_width"
  PANEL_WIDTH=$((TERM_WIDTH - 8))
  if [ "$PANEL_WIDTH" -lt 68 ]; then
    PANEL_WIDTH=68
  fi
  if [ "$PANEL_WIDTH" -gt 104 ]; then
    PANEL_WIDTH=104
  fi
}

repeat_char() {
  char="$1"
  count="$2"
  output=""
  while [ "$count" -gt 0 ]; do
    output="${output}${char}"
    count=$((count - 1))
  done
  printf '%s' "$output"
}

center_text() {
  text="$1"
  width="$2"
  text_length=${#text}
  if [ "$text_length" -ge "$width" ]; then
    printf '%s' "$text"
    return
  fi
  left_padding=$(((width - text_length) / 2))
  right_padding=$((width - text_length - left_padding))
  printf '%*s%s%*s' "$left_padding" "" "$text" "$right_padding" ""
}

box_border() {
  printf '%b+%s+%b\n' "$FRAME" "$(repeat_char "=" "$PANEL_WIDTH")" "$RESET"
}

box_rule() {
  printf '%b|%s|%b\n' "$FRAME" "$(repeat_char "-" "$PANEL_WIDTH")" "$RESET"
}

box_line_center() {
  text="$1"
  color="${2:-$VALUE_COLOR}"
  padded="$(center_text "$text" "$PANEL_WIDTH")"
  printf '%b|%b%s%b|%b\n' "$FRAME" "$color" "$padded" "$RESET" "$RESET"
}

box_line_left() {
  text="$1"
  color="${2:-$VALUE_COLOR}"
  printf '%b|%b %-*s %b|%b\n' "$FRAME" "$color" $((PANEL_WIDTH - 2)) "$text" "$RESET" "$RESET"
}

box_blank() {
  printf '%b|%*s|%b\n' "$FRAME" "$PANEL_WIDTH" "" "$RESET"
}

clear_screen() {
  printf '\033[2J\033[H'
}

info() {
  printf '%b[%s]%b %s\n' "$INFO_COLOR$BOLD" "INFO" "$RESET" "$*"
}

success() {
  printf '%b[%s]%b %s\n' "$SUCCESS_COLOR$BOLD" "OK" "$RESET" "$*"
}

warning() {
  printf '%b[%s]%b %s\n' "$WARN_COLOR$BOLD" "WARN" "$RESET" "$*"
}

error_line() {
  printf '%b[%s]%b %s\n' "$ERROR_COLOR$BOLD" "ERROR" "$RESET" "$*"
}

menu_hint() {
  printf '%b%s%b\n' "$DIM" "$*" "$RESET"
}

prompt_input() {
  printf '%b> %b' "$PROMPT_COLOR$BOLD" "$RESET"
}

normalize_input() {
  printf '%s' "${1%$'\r'}"
}

installed_version() {
  (
    cd "$REPO_DIR" || exit 1
    "$PYTHON_BIN" -c 'from pilottunnel.__version__ import VERSION; print(VERSION)'
  ) 2>/dev/null || printf '%s\n' "unknown"
}

role_label() {
  case "$1" in
    controller) printf '%s\n' "Iran side / controller" ;;
    worker) printf '%s\n' "Kharej side / worker" ;;
    *) printf '%s\n' "not configured" ;;
  esac
}

side_name() {
  case "$1" in
    controller) printf '%s\n' "Iran side" ;;
    worker) printf '%s\n' "Kharej side" ;;
    *) printf '%s\n' "not configured" ;;
  esac
}

current_node_snapshot() {
  (
    cd "$REPO_DIR" || exit 1
    "$PYTHON_BIN" - "$CONFIG_FILE" "$BASE_DIR" "$STATE_DIR" "$WORK_DIR" <<'PY'
from pathlib import Path
import sys

from pilottunnel.config import load_config

config = load_config(Path(sys.argv[1]))
default_install_root = sys.argv[2]
default_state_directory = sys.argv[3]
default_work_directory = sys.argv[4]
role = config.node.normalized_role
role_label = {
    "controller": "Iran side / controller",
    "worker": "Kharej side / worker",
}.get(role, "not configured")
values = [
    "true" if config.node.initialized else "false",
    role,
    role_label,
    config.node.display_name or "",
    config.node.install_root or default_install_root,
    config.node.state_directory or default_state_directory,
    config.node.work_directory or default_work_directory,
    config.node.endpoint_address or "",
    config.node.notes or "",
    config.node.node_id or "",
    str(Path(sys.argv[1])),
    config.node.preferred_layer or "",
    str(len(config.node.managed_remote_endpoints or [])),
]
for value in values:
    print(str(value).replace("\n", " ").strip())
PY
  )
}

load_node_snapshot() {
  mapfile -t snapshot < <(current_node_snapshot)
  NODE_INITIALIZED="$(normalize_input "${snapshot[0]:-false}")"
  NODE_ROLE="$(normalize_input "${snapshot[1]:-}")"
  NODE_ROLE_LABEL="$(normalize_input "${snapshot[2]:-not configured}")"
  NODE_DISPLAY_NAME="$(normalize_input "${snapshot[3]:-}")"
  NODE_INSTALL_ROOT="$(normalize_input "${snapshot[4]:-$BASE_DIR}")"
  NODE_STATE_DIRECTORY="$(normalize_input "${snapshot[5]:-$STATE_DIR}")"
  NODE_WORK_DIRECTORY="$(normalize_input "${snapshot[6]:-$WORK_DIR}")"
  NODE_ENDPOINT_ADDRESS="$(normalize_input "${snapshot[7]:-}")"
  NODE_NOTES="$(normalize_input "${snapshot[8]:-}")"
  NODE_ID="$(normalize_input "${snapshot[9]:-}")"
  NODE_CONFIG_PATH="$(normalize_input "${snapshot[10]:-$CONFIG_FILE}")"
  NODE_PREFERRED_LAYER="$(normalize_input "${snapshot[11]:-}")"
  NODE_MANAGED_ENDPOINT_COUNT="$(normalize_input "${snapshot[12]:-0}")"
}

current_link_snapshot() {
  (
    cd "$REPO_DIR" || exit 1
    "$PYTHON_BIN" - "$CONFIG_FILE" <<'PY'
from pathlib import Path
import sys

from pilottunnel.config import load_config
from pilottunnel.links import get_active_link

config = load_config(Path(sys.argv[1]))
link = get_active_link(config)
values = [
    str(len(config.links)),
    getattr(link, "label", "") or "",
    getattr(link, "iran_address", "") or "",
    "" if getattr(link, "iran_main_port", None) is None else str(link.iran_main_port),
    "" if link is None else str(link.tunnel_port),
    "" if link is None else str(link.config_port),
    getattr(link, "kharej_address", "") or "",
    getattr(link, "status", "") or "",
]
for value in values:
    print(str(value).replace("\n", " ").strip())
PY
  )
}

load_link_snapshot() {
  mapfile -t snapshot < <(current_link_snapshot)
  CURRENT_LINK_COUNT="$(normalize_input "${snapshot[0]:-0}")"
  CURRENT_LINK_LABEL="$(normalize_input "${snapshot[1]:-}")"
  CURRENT_IRAN_ADDRESS="$(normalize_input "${snapshot[2]:-}")"
  CURRENT_IRAN_MAIN_PORT="$(normalize_input "${snapshot[3]:-}")"
  CURRENT_TUNNEL_PORT="$(normalize_input "${snapshot[4]:-}")"
  CURRENT_CONFIG_PORT="$(normalize_input "${snapshot[5]:-}")"
  CURRENT_KHAREJ_ADDRESS="$(normalize_input "${snapshot[6]:-}")"
  CURRENT_LINK_STATUS="$(normalize_input "${snapshot[7]:-}")"
}

run_cli_capture() {
  LAST_CAPTURE_STDOUT="$(mktemp)"
  LAST_CAPTURE_STDERR="$(mktemp)"
  if ! pt_cli "$@" >"$LAST_CAPTURE_STDOUT" 2>"$LAST_CAPTURE_STDERR"; then
    return 1
  fi
  return 0
}

cleanup_capture() {
  [ -n "${LAST_CAPTURE_STDOUT:-}" ] && rm -f "$LAST_CAPTURE_STDOUT"
  [ -n "${LAST_CAPTURE_STDERR:-}" ] && rm -f "$LAST_CAPTURE_STDERR"
  LAST_CAPTURE_STDOUT=""
  LAST_CAPTURE_STDERR=""
}

capture_json_message() {
  "$PYTHON_BIN" - "$LAST_CAPTURE_STDOUT" "$LAST_CAPTURE_STDERR" <<'PY'
from pathlib import Path
import json
import sys

stdout_path = Path(sys.argv[1])
stderr_path = Path(sys.argv[2])
text = stdout_path.read_text(encoding="utf-8", errors="replace").strip()
if text:
    try:
        payload = json.loads(text)
    except Exception:
        print(" ".join(text.split()))
        raise SystemExit(0)
    if isinstance(payload, dict):
        message = payload.get("message")
        if message:
            print(str(message))
            raise SystemExit(0)
stderr = stderr_path.read_text(encoding="utf-8", errors="replace").strip()
if stderr:
    print(" ".join(stderr.split()))
PY
}

debug_capture_if_enabled() {
  [ "$MENU_DEBUG" = "1" ] || return 0
  [ -n "${LAST_CAPTURE_STDOUT:-}" ] && [ -s "$LAST_CAPTURE_STDOUT" ] && cat "$LAST_CAPTURE_STDOUT"
  [ -n "${LAST_CAPTURE_STDERR:-}" ] && [ -s "$LAST_CAPTURE_STDERR" ] && cat "$LAST_CAPTURE_STDERR" >&2
}

apply_role_change() {
  role="$1"
  force_flag="$2"
  if [ "$force_flag" = "true" ]; then
    if ! run_cli_capture init --force --role "$role"; then
      message="$(capture_json_message)"
      debug_capture_if_enabled
      cleanup_capture
      error_line "${message:-Role reconfiguration failed.}"
      return 1
    fi
  else
    if ! run_cli_capture init --role "$role"; then
      message="$(capture_json_message)"
      debug_capture_if_enabled
      cleanup_capture
      error_line "${message:-Role initialization failed.}"
      return 1
    fi
  fi
  debug_capture_if_enabled
  cleanup_capture

  load_node_snapshot
  if [ -z "$NODE_PREFERRED_LAYER" ]; then
    if ! run_cli_capture layer select --layer layer4; then
      message="$(capture_json_message)"
      debug_capture_if_enabled
      cleanup_capture
      warning "${message:-Unable to select the default preferred layer.}"
      return 0
    fi
    debug_capture_if_enabled
    cleanup_capture
  fi
  return 0
}

save_node_setup_metadata() {
  export PT_NODE_ROLE="$1"
  export PT_NODE_DISPLAY_NAME="$2"
  export PT_NODE_INSTALL_ROOT="$3"
  export PT_NODE_STATE_DIRECTORY="$4"
  export PT_NODE_WORK_DIRECTORY="$5"
  export PT_NODE_ENDPOINT_ADDRESS="$6"
  export PT_NODE_NOTES="$7"

  (
    cd "$REPO_DIR" || exit 1
    "$PYTHON_BIN" - "$CONFIG_FILE" <<'PY'
import os
import sys
from pathlib import Path

from pilottunnel.config import load_config, save_config

config_path = Path(sys.argv[1])
config = load_config(config_path)
config.node.display_name = os.environ.get("PT_NODE_DISPLAY_NAME", "").strip()
config.node.install_root = os.environ.get("PT_NODE_INSTALL_ROOT", "").strip()
config.node.state_directory = os.environ.get("PT_NODE_STATE_DIRECTORY", "").strip()
config.node.work_directory = os.environ.get("PT_NODE_WORK_DIRECTORY", "").strip()
config.node.endpoint_address = os.environ.get("PT_NODE_ENDPOINT_ADDRESS", "").strip()
config.node.notes = os.environ.get("PT_NODE_NOTES", "").strip()
if config.node.normalized_role == "controller":
    config.node.managed_remote_endpoints = list(config.node.managed_remote_endpoints or [])
else:
    config.node.managed_remote_endpoints = list(config.node.managed_remote_endpoints or [])
save_config(config, config_path)
PY
  )
}

show_node_status_summary() {
  (
    cd "$REPO_DIR" || exit 1
    "$PYTHON_BIN" - "$CONFIG_FILE" <<'PY'
import sys
from pathlib import Path

from pilottunnel.config import load_config
from pilottunnel.node_role import node_status_payload

config_path = Path(sys.argv[1])
config = load_config(config_path)
payload = node_status_payload(config, str(config_path))
role = payload.get("normalized_role") or ""
role_label = {
    "controller": "Iran side / controller",
    "worker": "Kharej side / worker",
}.get(role, "not configured")
print(f"Side: {role_label}")
print(f"Initialized: {'yes' if payload.get('initialized') else 'no'}")
print(f"Node ID: {payload.get('node_id') or 'not assigned'}")
if role == "controller":
    print(f"Link count: {payload.get('link_count', 0)}")
elif role == "worker":
    print(f"Active link: {payload.get('active_link_label') or 'not configured'}")
print(f"Config path: {payload.get('config_path')}")
print(f"Preferred layer: {payload.get('preferred_layer') or 'not selected'}")
print(f"Allowed actions: {len(payload.get('allowed_actions') or [])}")
print(f"Blocked actions: {len(payload.get('blocked_actions') or [])}")
PY
  )
}

show_binary_status_summary() {
  (
    cd "$REPO_DIR" || exit 1
    "$PYTHON_BIN" - "$CONFIG_FILE" "$STATE_FILE" "$WORK_DIR" <<'PY'
import sys
from pathlib import Path
from urllib.parse import urlparse

from pilottunnel.binary_readiness import build_binary_readiness_report
from pilottunnel.config import load_config
from pilottunnel.state import load_state

config = load_config(Path(sys.argv[1]))
state = load_state(Path(sys.argv[2]))
work_dir = Path(sys.argv[3])
manifest_ref = config.binary_resolution.provider_manifest
allow_host = config.binary_resolution.provider_allow_host or None
manifest_url = None
manifest_file = None

if manifest_ref:
    parsed = urlparse(manifest_ref)
    if parsed.scheme in {"http", "https"}:
        manifest_url = manifest_ref
    else:
        manifest_file = Path(manifest_ref)

if not manifest_url and not manifest_file:
    print("Binary readiness: warning")
    print("Provider manifest: not configured")
    print("Tip: run the installer with managed binaries or configure a provider manifest first.")
    raise SystemExit(0)

try:
    payload = build_binary_readiness_report(
        cache_root=work_dir,
        state=state,
        manifest_url=manifest_url,
        manifest_file=manifest_file,
        allow_provider_host=allow_host,
        require_all=True,
    )
except Exception as exc:
    print("Binary readiness: warning")
    print(f"Provider manifest check: {exc}")
    raise SystemExit(0)
required = payload.get("required_adapters") or []
verified = payload.get("verified_adapters") or []
missing = payload.get("missing_adapters") or []
print(f"Required binaries verified: {len(verified)}/{len(required)}")
if missing:
    print("Missing binaries: " + ", ".join(missing))
else:
    print("Missing binaries: none")
for item in payload.get("results") or []:
    if not item.get("required_for_v0_1"):
        continue
    status = "OK" if item.get("verified") else "missing"
    print(f"- {item.get('adapter')}: {status}")
PY
  )
}

show_readiness_summary() {
  (
    cd "$REPO_DIR" || exit 1
    "$PYTHON_BIN" - "$CONFIG_FILE" "$STATE_FILE" "$REGISTRY_FILE" "$STAGING_ROOT" "$INSTALL_ROOT" <<'PY'
from pathlib import Path
import sys

from pilottunnel.config import load_config
from pilottunnel.readiness import build_readiness_report
from pilottunnel.registry import load_registry
from pilottunnel.state import load_state
from pilottunnel.switch_engine import SwitchPaths

config_path = Path(sys.argv[1])
state_path = Path(sys.argv[2])
registry_path = Path(sys.argv[3])
staging_root = Path(sys.argv[4])
install_root = Path(sys.argv[5])

config = load_config(config_path)
state = load_state(state_path)
registry = load_registry(registry_path)
switch_paths = SwitchPaths(
    config_path=config_path,
    state_path=state_path,
    registry_path=registry_path,
    audit_path=Path(config_path.parent / "audit.log"),
    lock_dir=Path(config_path.parent / "locks"),
    work_dir=Path(config_path.parent.parent / "work"),
    staging_root=staging_root,
)
payload = build_readiness_report(
    config=config,
    state=state,
    registry=registry,
    config_path=config_path,
    switch_paths=switch_paths,
    profile_name=None,
    adapter_name=None,
    transport=None,
    staging_root=staging_root,
    install_root=install_root,
)
print(f"Readiness: {payload.get('readiness_level')}")
print(f"Role initialized: {'yes' if payload.get('role_initialized') else 'no'}")
print(f"Node role: {payload.get('node_role') or 'not configured'}")
print(f"Systemd available: {'yes' if payload.get('systemd_available') else 'no'}")
print(f"Binary imported: {'yes' if payload.get('binary_imported') else 'no'}")
print(f"Service plan available: {'yes' if payload.get('service_plan_available') else 'no'}")
blockers = payload.get("blockers") or []
warnings = payload.get("warnings") or []
if blockers:
    print("Blockers:")
    for item in blockers[:5]:
        print(f"- {item}")
if warnings:
    print("Warnings:")
    for item in warnings[:5]:
        print(f"- {item}")
PY
  )
}

render_banner() {
  box_border
  box_blank
  box_line_center " ____  _ _       _   _____                    _ " "$TITLE$BOLD"
  box_line_center "|  _ \\(_) | ___ | |_|_   _|   _ _ __  _ __   | |" "$TITLE$BOLD"
  box_line_center "| |_) | | |/ _ \\| __| | || | | | '_ \\| '_ \\  | |" "$TITLE$BOLD"
  box_line_center "|  __/| | | (_) | |_  | || |_| | | | | | | | |_|" "$TITLE$BOLD"
  box_line_center "|_|   |_|_|\\___/ \\__| |_| \\__,_|_| |_|_| |_| (_)" "$TITLE$BOLD"
  box_blank
  box_line_center "Safety-first multi-layer tunnel management" "$ACCENT$BOLD"
  box_line_center "Setup, readiness, binaries, and guarded operations" "$DIM"
  box_rule
}

render_status_panel() {
  version_text="$1"
  load_node_snapshot
  box_line_left "PilotTunnel Menu" "$ACCENT$BOLD"
  box_line_left "Version: ${version_text}" "$VALUE_COLOR"
  box_line_left "Current role: ${NODE_ROLE_LABEL}" "$VALUE_COLOR"
  box_line_left "Node label: ${NODE_DISPLAY_NAME:-not set}" "$VALUE_COLOR"
  box_line_left "Install root: ${BASE_DIR}" "$VALUE_COLOR"
  box_border
}

show_header() {
  clear_screen
  render_banner
  render_status_panel "$(installed_version)"
}

section_heading() {
  printf '\n%b%s%b\n' "$ACCENT$BOLD" "$1" "$RESET"
  printf '%b%s%b\n' "$FRAME" "$(repeat_char "-" 60)" "$RESET"
}

pause_menu() {
  printf '\n%bPress Enter to return to the menu...%b' "$DIM" "$RESET"
  IFS= read -r _ || true
}

map_role_selection() {
  case "$1" in
    1|controller) printf '%s\n' "controller" ;;
    2|worker) printf '%s\n' "worker" ;;
    *) return 1 ;;
  esac
}

prompt_with_default() {
  prompt_label="$1"
  default_value="$2"
  if [ -n "$default_value" ]; then
    printf '%b%s%b [%s]: ' "$PROMPT_COLOR$BOLD" "$prompt_label" "$RESET" "$default_value"
  else
    printf '%b%s%b: ' "$PROMPT_COLOR$BOLD" "$prompt_label" "$RESET"
  fi
  IFS= read -r input_value || return 1
  input_value="$(normalize_input "$input_value")"
  if [ -n "$input_value" ]; then
    PROMPT_RESULT="$input_value"
  else
    PROMPT_RESULT="$default_value"
  fi
}

show_setup_summary() {
  role_value="$1"
  load_link_snapshot
  show_header
  section_heading "Setup complete"
  printf '%bSide: %s%b\n' "$VALUE_COLOR$BOLD" "$(role_label "$role_value")" "$RESET"
  printf '%bLink label: %s%b\n' "$VALUE_COLOR$BOLD" "${CURRENT_LINK_LABEL:-not configured}" "$RESET"
  printf '%bIran address: %s%b\n' "$VALUE_COLOR$BOLD" "${CURRENT_IRAN_ADDRESS:-not configured}" "$RESET"
  printf '%bTunnel port: %s%b\n' "$VALUE_COLOR$BOLD" "${CURRENT_TUNNEL_PORT:-not configured}" "$RESET"
  printf '%bConfig port: %s%b\n' "$VALUE_COLOR$BOLD" "${CURRENT_CONFIG_PORT:-not configured}" "$RESET"
  if [ "$role_value" = "controller" ]; then
    printf '%bMain public port: %s%b\n' "$VALUE_COLOR$BOLD" "${CURRENT_IRAN_MAIN_PORT:-not configured}" "$RESET"
    printf '%bKharej address: %s%b\n' "$VALUE_COLOR$BOLD" "${CURRENT_KHAREJ_ADDRESS:-not configured}" "$RESET"
  fi

  binary_summary="$(show_binary_status_summary)"
  if printf '%s\n' "$binary_summary" | grep -qi "Missing binaries: none"; then
    printf '%bBinary readiness:%b OK\n' "$VALUE_COLOR$BOLD" "$RESET"
  else
    printf '%bBinary readiness:%b warning\n' "$VALUE_COLOR$BOLD" "$RESET"
  fi
  printf '\n%s\n' "$binary_summary"
  printf '\n%bNext step:%b ' "$ACCENT$BOLD" "$RESET"
  if [ "$role_value" = "controller" ]; then
    printf '%s\n' "generate tunnel candidates for this link."
  else
    printf '%s\n' "prepare this endpoint for candidate testing."
  fi
}

show_current_setup_panel() {
  printf '%bCurrent setup:%b\n' "$VALUE_COLOR$BOLD" "$RESET"
  printf 'Side: %s\n' "$NODE_ROLE_LABEL"
  if [ -n "$CURRENT_LINK_LABEL" ]; then
    printf 'Link label: %s\n' "$CURRENT_LINK_LABEL"
    printf 'Iran address: %s\n' "$CURRENT_IRAN_ADDRESS"
    printf 'Tunnel port: %s\n' "$CURRENT_TUNNEL_PORT"
    printf 'Config port: %s\n' "$CURRENT_CONFIG_PORT"
    if [ "$NODE_ROLE" = "controller" ]; then
      printf 'Main public port: %s\n' "$CURRENT_IRAN_MAIN_PORT"
      printf 'Kharej address: %s\n' "$CURRENT_KHAREJ_ADDRESS"
    fi
  else
    printf 'Link label: not configured\n'
  fi
}

prompt_required_text() {
  prompt_label="$1"
  default_value="$2"
  while true; do
    prompt_with_default "$prompt_label" "$default_value" || return 1
    candidate="$(printf '%s' "$PROMPT_RESULT" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    if [ -n "$candidate" ]; then
      PROMPT_RESULT="$candidate"
      return 0
    fi
    warning "$prompt_label is required."
  done
}

prompt_port_value() {
  prompt_label="$1"
  default_value="$2"
  while true; do
    prompt_with_default "$prompt_label" "$default_value" || return 1
    candidate="$(printf '%s' "$PROMPT_RESULT" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    if printf '%s' "$candidate" | grep -Eq '^[0-9]+$' && [ "$candidate" -ge 1 ] && [ "$candidate" -le 65535 ]; then
      PROMPT_RESULT="$candidate"
      return 0
    fi
    warning "$prompt_label must be an integer between 1 and 65535."
  done
}

prompt_optional_label_value() {
  prompt_label="$1"
  default_value="$2"
  while true; do
    prompt_with_default "$prompt_label" "$default_value" || return 1
    candidate="$(printf '%s' "$PROMPT_RESULT" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    if [ -z "$candidate" ]; then
      PROMPT_RESULT=""
      return 0
    fi
    if printf '%s' "$candidate" | grep -Eq '^[A-Za-z0-9_-]+$'; then
      PROMPT_RESULT="$candidate"
      return 0
    fi
    warning "Link label may contain only letters, numbers, dashes, and underscores."
  done
}

select_role_for_setup() {
  while true; do
    show_header
    section_heading "Setup / Configure this server"
    load_link_snapshot
    if [ "$NODE_INITIALIZED" = "true" ]; then
      show_current_setup_panel
      printf '\n%b%s%b\n' "$VALUE_COLOR$BOLD" "1. Keep current setup" "$RESET"
      printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "2. Reconfigure setup" "$RESET"
      printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "3. Back" "$RESET"
      printf '\n'
      prompt_input
      IFS= read -r current_selection || return 1
      current_selection="$(normalize_input "$current_selection")"
      case "$current_selection" in
        1)
          SELECTED_ROLE="$NODE_ROLE"
          ROLE_CHANGE_MODE="keep"
          return 0
          ;;
        2)
          ROLE_CHANGE_MODE="reconfigure"
          ;;
        3) return 1 ;;
        *) warning "Enter a number from 1 to 3."; pause_menu; continue ;;
      esac
    else
      printf '%bCurrent state:%b not configured\n' "$VALUE_COLOR$BOLD" "$RESET"
      ROLE_CHANGE_MODE="new"
    fi

    show_header
    section_heading "Choose the side for this server"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "1. Iran side" "$RESET"
    menu_hint "   Public/user-facing entry side. This side will manage future tunnel candidates."
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "2. Kharej side" "$RESET"
    menu_hint "   Remote endpoint side. This side will be prepared for future candidate testing."
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "3. Back" "$RESET"
    prompt_input
    IFS= read -r selection || return 1
    selection="$(normalize_input "$selection")"
    case "$selection" in
      1|2)
        if SELECTED_ROLE="$(map_role_selection "$selection")"; then
          return 0
        fi
        ;;
      3) return 1 ;;
      *) warning "Enter 1, 2, or 3."; pause_menu ;;
    esac
  done
}

run_setup_wizard() {
  load_node_snapshot
  load_link_snapshot
  if ! select_role_for_setup; then
    return
  fi

  if [ "$ROLE_CHANGE_MODE" = "keep" ] && [ -n "$CURRENT_LINK_LABEL" ]; then
    show_setup_summary "$SELECTED_ROLE"
    return
  fi

  while true; do
    show_header
    section_heading "Link setup"
    if [ "$SELECTED_ROLE" = "controller" ]; then
      menu_hint "Iran side stores one or more Kharej links for future candidate generation."
      prompt_required_text "Iran IP / domain" "$CURRENT_IRAN_ADDRESS" || return
      iran_address="$PROMPT_RESULT"
      printf '\n'
      prompt_port_value "Main public/user-facing port on Iran side" "$CURRENT_IRAN_MAIN_PORT" || return
      main_port="$PROMPT_RESULT"
      printf '\n'
      prompt_port_value "Tunnel port between Iran and Kharej" "$CURRENT_TUNNEL_PORT" || return
      tunnel_port="$PROMPT_RESULT"
      printf '\n'
      prompt_port_value "Config/service port" "$CURRENT_CONFIG_PORT" || return
      config_port="$PROMPT_RESULT"
      printf '\n'
      prompt_required_text "Kharej IP / domain" "$CURRENT_KHAREJ_ADDRESS" || return
      kharej_address="$PROMPT_RESULT"
      printf '\n'
      prompt_optional_label_value "Optional link label" "$CURRENT_LINK_LABEL" || return
      link_label="$PROMPT_RESULT"
      printf '\n'
    else
      menu_hint "Kharej side stores the active endpoint link for future candidate testing."
      prompt_required_text "Iran IP / domain" "$CURRENT_IRAN_ADDRESS" || return
      iran_address="$PROMPT_RESULT"
      printf '\n'
      prompt_port_value "Tunnel port between Iran and Kharej" "$CURRENT_TUNNEL_PORT" || return
      tunnel_port="$PROMPT_RESULT"
      printf '\n'
      prompt_port_value "Config/service port" "$CURRENT_CONFIG_PORT" || return
      config_port="$PROMPT_RESULT"
      printf '\n'
      prompt_optional_label_value "Optional link label" "$CURRENT_LINK_LABEL" || return
      link_label="$PROMPT_RESULT"
      printf '\n'
    fi

    if [ "$ROLE_CHANGE_MODE" = "new" ]; then
      apply_role_change "$SELECTED_ROLE" "false" || return
    elif [ "$ROLE_CHANGE_MODE" = "reconfigure" ]; then
      apply_role_change "$SELECTED_ROLE" "true" || return
    fi

    if [ "$SELECTED_ROLE" = "controller" ]; then
      cli_args=(link setup-iran --iran-address "$iran_address" --main-port "$main_port" --tunnel-port "$tunnel_port" --config-port "$config_port" --kharej-address "$kharej_address")
    else
      cli_args=(link setup-kharej --iran-address "$iran_address" --tunnel-port "$tunnel_port" --config-port "$config_port")
    fi
    if [ -n "$link_label" ]; then
      cli_args+=(--label "$link_label")
    fi
    if [ "$ROLE_CHANGE_MODE" != "new" ] && [ -n "$CURRENT_LINK_LABEL" ]; then
      cli_args+=(--replace-label "$CURRENT_LINK_LABEL")
    fi

    if ! run_cli_capture "${cli_args[@]}"; then
      message="$(capture_json_message)"
      debug_capture_if_enabled
      cleanup_capture
      warning "${message:-Unable to save link setup. Please try again.}"
      pause_menu
      continue
    fi
    debug_capture_if_enabled
    cleanup_capture
    load_node_snapshot
    load_link_snapshot
    show_setup_summary "$SELECTED_ROLE"
    return
  done
}

show_status() {
  show_header
  section_heading "Node status"
  show_node_status_summary
}

show_readiness() {
  show_header
  section_heading "Readiness report"
  show_readiness_summary
}

show_binary_status() {
  show_header
  section_heading "Binary status"
  show_binary_status_summary
}

prompt_service_identity() {
  printf '%bProfile:%b ' "$PROMPT_COLOR$BOLD" "$RESET"
  IFS= read -r SERVICE_PROFILE || return 1
  SERVICE_PROFILE="$(normalize_input "$SERVICE_PROFILE")"
  printf '%bAdapter:%b ' "$PROMPT_COLOR$BOLD" "$RESET"
  IFS= read -r SERVICE_ADAPTER || return 1
  SERVICE_ADAPTER="$(normalize_input "$SERVICE_ADAPTER")"
  printf '%bTransport:%b ' "$PROMPT_COLOR$BOLD" "$RESET"
  IFS= read -r SERVICE_TRANSPORT || return 1
  SERVICE_TRANSPORT="$(normalize_input "$SERVICE_TRANSPORT")"
  [ -n "$SERVICE_PROFILE" ] && [ -n "$SERVICE_ADAPTER" ] && [ -n "$SERVICE_TRANSPORT" ] || {
    warning "Profile, adapter, and transport are required."
    return 1
  }
}

prompt_service_action() {
  printf '%bAction (start/stop/restart/enable/disable):%b ' "$PROMPT_COLOR$BOLD" "$RESET"
  IFS= read -r SERVICE_ACTION || return 1
  SERVICE_ACTION="$(normalize_input "$SERVICE_ACTION")"
  case "$SERVICE_ACTION" in
    start) SERVICE_CONFIRM_TOKEN="START_SERVICE" ;;
    stop) SERVICE_CONFIRM_TOKEN="STOP_SERVICE" ;;
    restart) SERVICE_CONFIRM_TOKEN="RESTART_SERVICE" ;;
    enable) SERVICE_CONFIRM_TOKEN="ENABLE_SERVICE" ;;
    disable) SERVICE_CONFIRM_TOKEN="DISABLE_SERVICE" ;;
    *) warning "Unsupported service action."; return 1 ;;
  esac
}

service_plan() {
  prompt_service_identity || return
  prompt_service_action || return
  section_heading "Service plan"
  pt_cli service plan \
    --profile "$SERVICE_PROFILE" \
    --adapter "$SERVICE_ADAPTER" \
    --transport "$SERVICE_TRANSPORT" \
    --action "$SERVICE_ACTION"
}

service_status() {
  prompt_service_identity || return
  section_heading "Read-only service status"
  pt_cli service status \
    --profile "$SERVICE_PROFILE" \
    --adapter "$SERVICE_ADAPTER" \
    --transport "$SERVICE_TRANSPORT" \
    --real-systemd
}

service_apply() {
  prompt_service_identity || return
  prompt_service_action || return
  section_heading "Service plan"
  pt_cli service plan \
    --profile "$SERVICE_PROFILE" \
    --adapter "$SERVICE_ADAPTER" \
    --transport "$SERVICE_TRANSPORT" \
    --action "$SERVICE_ACTION" || return
  printf '\n%bType %s to apply this action:%b ' "$WARN_COLOR$BOLD" "$SERVICE_CONFIRM_TOKEN" "$RESET"
  IFS= read -r confirmation || return
  confirmation="$(normalize_input "$confirmation")"
  if [ "$confirmation" != "$SERVICE_CONFIRM_TOKEN" ]; then
    warning "Service action cancelled."
    return
  fi
  pt_cli service "$SERVICE_ACTION" \
    --profile "$SERVICE_PROFILE" \
    --adapter "$SERVICE_ADAPTER" \
    --transport "$SERVICE_TRANSPORT" \
    --real-systemd \
    --confirm "$SERVICE_CONFIRM_TOKEN"
}

service_menu() {
  while true; do
    show_header
    section_heading "Service management"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "1. Read-only service status" "$RESET"
    menu_hint "   Inspect managed service state without changing it."
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "2. Plan an action" "$RESET"
    menu_hint "   Preview a guarded service operation."
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "3. Apply a guarded action" "$RESET"
    menu_hint "   Confirmation is always required for live service operations."
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "4. Back" "$RESET"
    printf '\n'
    menu_hint "Safety: no service action runs without confirmation."
    prompt_input
    IFS= read -r selection || return
    selection="$(normalize_input "$selection")"
    case "$selection" in
      1) service_status; pause_menu ;;
      2) service_plan; pause_menu ;;
      3) service_apply; pause_menu ;;
      4) return ;;
      *) warning "Enter a number from 1 to 4."; pause_menu ;;
    esac
  done
}

backup_restore_menu() {
  while true; do
    show_header
    section_heading "Backup / Restore"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "1. List backups" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "2. Create a guarded backup" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "3. Plan a restore" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "4. Apply a guarded restore" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "5. Back" "$RESET"
    printf '\n'
    menu_hint "Safety: restore remains confirmation-gated."
    prompt_input
    IFS= read -r selection || return
    selection="$(normalize_input "$selection")"
    case "$selection" in
      1) section_heading "Backup list"; pt_cli backup list; pause_menu ;;
      2)
        section_heading "Backup plan"
        pt_cli backup plan || { pause_menu; continue; }
        printf '\n%bType BACKUP_CREATE to create the backup:%b ' "$WARN_COLOR$BOLD" "$RESET"
        IFS= read -r confirmation || return
        confirmation="$(normalize_input "$confirmation")"
        [ "$confirmation" = "BACKUP_CREATE" ] && pt_cli backup create --confirm BACKUP_CREATE || warning "Backup cancelled."
        pause_menu
        ;;
      3)
        printf '%bBackup ID:%b ' "$PROMPT_COLOR$BOLD" "$RESET"
        IFS= read -r backup_id || return
        backup_id="$(normalize_input "$backup_id")"
        section_heading "Restore plan"
        pt_cli restore plan --backup-id "$backup_id"
        pause_menu
        ;;
      4)
        printf '%bBackup ID:%b ' "$PROMPT_COLOR$BOLD" "$RESET"
        IFS= read -r backup_id || return
        backup_id="$(normalize_input "$backup_id")"
        section_heading "Restore plan"
        pt_cli restore plan --backup-id "$backup_id" || { pause_menu; continue; }
        printf '\n%bType RESTORE_APPLY to restore this backup:%b ' "$WARN_COLOR$BOLD" "$RESET"
        IFS= read -r confirmation || return
        confirmation="$(normalize_input "$confirmation")"
        [ "$confirmation" = "RESTORE_APPLY" ] && pt_cli restore apply --backup-id "$backup_id" --confirm RESTORE_APPLY || warning "Restore cancelled."
        pause_menu
        ;;
      5) return ;;
      *) warning "Enter a number from 1 to 5."; pause_menu ;;
    esac
  done
}

main_menu() {
  while true; do
    show_header
    printf '\n%b%s%b\n' "$ACCENT$BOLD" "Choose an action" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "1. Setup / Configure this server" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "2. Status" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "3. Readiness report" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "4. Binary status" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "5. Service management" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "6. Backup / Restore" "$RESET"
    printf '%b%s%b\n' "$VALUE_COLOR$BOLD" "7. Exit" "$RESET"
    printf '\n'
    menu_hint "Select an option and press Enter."
    menu_hint "Safety: no service action runs without confirmation."
    prompt_input
    IFS= read -r selection || return
    selection="$(normalize_input "$selection")"
    case "$selection" in
      1) run_setup_wizard; pause_menu ;;
      2) show_status; pause_menu ;;
      3) show_readiness; pause_menu ;;
      4) show_binary_status; pause_menu ;;
      5) service_menu ;;
      6) backup_restore_menu ;;
      7) success "Goodbye."; return ;;
      *) warning "Enter a number from 1 to 7."; pause_menu ;;
    esac
  done
}

main() {
  parse_args "$@"
  init_theme
  PYTHON_BIN="$(find_python)"
  [ -n "$PYTHON_BIN" ] || fail "Python is required but was not found."
  prepare_paths
  if [ "${PILOTTUNNEL_MENU_ALLOW_NON_TTY:-0}" != "1" ]; then
    [ -t 0 ] && [ -t 1 ] || fail "PilotTunnel Menu requires an interactive terminal."
  fi
  main_menu
}

if [ "${BASH_SOURCE[0]}" = "$0" ]; then
  main "$@"
fi
